<UserControl x:Class="AiInterviewAssistant.PastSessionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:local="clr-namespace:AiInterviewAssistant"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="Transparent"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <Style x:Key="MenuRowButton" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F1F5F9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MenuTinyIconBtn" TargetType="Border">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FAFC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SessionRowText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Border Background="#FFFFFF"
            CornerRadius="20"
            BorderBrush="#E2E8F0"
            BorderThickness="1"
            Width="520"
            MinHeight="200"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Effect="{StaticResource OrioCardDropShadow}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <local:AppHeaderView x:Name="SharedHeader"
                                 Grid.Row="0"
                                 CreditsText="2 Credits"
                                 MoreClicked="Header_MoreClicked"
                                 MoveClicked="Header_MoveClicked"
                                 MinimizeClicked="Header_MinimizeClicked"
                                 CloseClicked="Header_CloseClicked"
                                 HeaderBackground="#E7EBF3"/>

            <Border Grid.Row="1" Padding="10,9,10,10" Background="White" CornerRadius="0,0,20,20">
                <StackPanel>
                    <Border Style="{StaticResource OrioTabSwitcherBarBorder}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="Transparent" CornerRadius="10" Padding="10,9" Cursor="Hand" MouseLeftButtonDown="CreateTab_Click">
                                <TextBlock Text="Create" HorizontalAlignment="Center" Foreground="#475569" FontSize="14" FontWeight="SemiBold"/>
                            </Border>
                            <Border Grid.Column="1" Background="White" CornerRadius="10" BorderBrush="#818CF8" BorderThickness="1.5" Padding="10,9">
                                <TextBlock Text="Past Sessions" HorizontalAlignment="Center" Foreground="#312E81" FontSize="14" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource OrioSessionsListPanelBorder}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="14,14,14,10">
                                <TextBlock Text="Session"
                                           Foreground="#312E81"
                                           FontSize="13.5"
                                           FontWeight="SemiBold"/>
                            </Grid>

                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="SessionsStatusText"
                                           Grid.Row="0"
                                           Margin="12,0,12,8"
                                           Foreground="#64748B"
                                           FontSize="12"
                                           Text="Loading sessions..."/>

                                <ListView x:Name="SessionsListView"
                                          Grid.Row="1"
                                          Margin="0"
                                          BorderThickness="0"
                                          Background="Transparent"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0"/>
                                            <Setter Property="Focusable" Value="False"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListViewItem">
                                                        <Border Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                                                            <ContentPresenter/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="14,10"
                                                    BorderBrush="#E8EDFF"
                                                    BorderThickness="0,0,0,1"
                                                    Background="Transparent"
                                                    Cursor="Hand"
                                                    MouseLeftButtonDown="SessionRow_Click">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="1.8*"/>
                                                        <ColumnDefinition Width="1.15*"/>
                                                        <ColumnDefinition Width="1.25*"/>
                                                        <ColumnDefinition Width="1.25*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Title}"
                                                               Style="{StaticResource SessionRowText}"/>

                                                    <Border Grid.Column="1"
                                                            Background="#4338CA"
                                                            BorderBrush="#6366F1"
                                                            BorderThickness="1"
                                                            CornerRadius="11"
                                                            Padding="8,3"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Language}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="White"/>
                                                    </Border>

                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding EndsIn}"
                                                               Style="{StaticResource SessionRowText}"
                                                               Foreground="#4B5563"/>

                                                    <TextBlock Grid.Column="3"
                                                               Text="{Binding CreatedAtDisplay}"
                                                               Style="{StaticResource SessionRowText}"
                                                               Foreground="#374151"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>

                            <Border Grid.Row="2"
                                    BorderBrush="#EEF2F7"
                                    BorderThickness="0,1,0,0"
                                    Background="Transparent"
                                    Padding="0,10,0,10"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="ViewAll_Click">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="View All" Foreground="#1F2937" FontSize="14" FontWeight="SemiBold"/>
                                    <iconPacks:PackIconMaterial Kind="OpenInNew" Width="15" Height="15" Foreground="#1F2937" Margin="6,0,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Popup x:Name="MoreOptionsPopup" Placement="Bottom" VerticalOffset="8" HorizontalOffset="-6" StaysOpen="True" AllowsTransparency="True" PopupAnimation="Fade">
                <Border MinWidth="272" MaxWidth="340" Background="#FFFFFF" CornerRadius="16" BorderBrush="#E2E8F0" BorderThickness="1" Padding="0" SnapsToDevicePixels="True">
                    <Border.Effect><DropShadowEffect BlurRadius="24" ShadowDepth="3" Direction="270" Opacity="0.12" Color="#0F172A"/></Border.Effect>
                    <StackPanel Margin="4,6,4,8">
                        <Border Style="{StaticResource MenuRowButton}" CornerRadius="12,12,0,0" MouseLeftButtonDown="MenuDashboard_Click">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="ViewDashboard" Width="20" Height="20" Foreground="#334155" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="Dashboard" FontSize="14.5" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Height="1" Background="#E2E8F0" Margin="14,6,14,0"/>
                        <Border Style="{StaticResource MenuRowDanger}" MouseLeftButtonDown="MenuLogout_Click">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Logout" Width="20" Height="20" Foreground="#DC2626" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="Logout" FontSize="14.5" FontWeight="SemiBold" Foreground="#DC2626" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Popup>

            <Popup x:Name="MoveOptionsPopup" Placement="Bottom" VerticalOffset="6" HorizontalOffset="-78" StaysOpen="True" AllowsTransparency="True" PopupAnimation="Fade">
                <Border Background="#FFFFFF" CornerRadius="14" BorderBrush="#E2E8F0" BorderThickness="1" Padding="12" SnapsToDevicePixels="True">
                    <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="2" Direction="270" Opacity="0.14" Color="#0F172A"/></Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource OrioMoveSlotBtnStyle}" MouseLeftButtonDown="MoveTopLeft_Click"><iconPacks:PackIconMaterial Kind="ArrowTopLeft" Width="20" Height="20" Foreground="#334155" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                        <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource OrioMoveSlotBtnStyle}" MouseLeftButtonDown="MoveTopCenter_Click"><iconPacks:PackIconMaterial Kind="ArrowUp" Width="20" Height="20" Foreground="#334155" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                        <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource OrioMoveSlotBtnStyle}" MouseLeftButtonDown="MoveTopRight_Click"><iconPacks:PackIconMaterial Kind="ArrowTopRight" Width="20" Height="20" Foreground="#334155" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource OrioMoveSlotBtnStyle}" MouseLeftButtonDown="MoveBottomLeft_Click"><iconPacks:PackIconMaterial Kind="ArrowBottomLeft" Width="20" Height="20" Foreground="#334155" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource OrioMoveSlotBtnStyle}" MouseLeftButtonDown="MoveBottomCenter_Click"><iconPacks:PackIconMaterial Kind="ArrowDown" Width="20" Height="20" Foreground="#334155" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                        <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource OrioMoveSlotBtnStyle}" MouseLeftButtonDown="MoveBottomRight_Click"><iconPacks:PackIconMaterial Kind="ArrowBottomRight" Width="20" Height="20" Foreground="#334155" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                    </Grid>
                </Border>
            </Popup>
        </Grid>
    </Border>
</UserControl>
