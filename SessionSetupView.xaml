<UserControl x:Class="AiInterviewAssistant.SessionSetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:local="clr-namespace:AiInterviewAssistant"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="Transparent"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <Style x:Key="DarkTooltipStyle" TargetType="ToolTip">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#111827"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Placement" Value="Top"/>
            <Setter Property="HasDropShadow" Value="False"/>
        </Style>

        <Style x:Key="MenuRowButton" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F1F5F9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MenuTinyIconBtn" TargetType="Border">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FAFC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MoveSlotBtn" TargetType="Border">
            <Setter Property="Width" Value="72"/>
            <Setter Property="Height" Value="56"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF2F7"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Background="#FFFFFF"
            CornerRadius="20"
            BorderBrush="#E2E8F0"
            BorderThickness="1"
            Width="520"
            MinHeight="200"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <local:AppHeaderView x:Name="SharedHeader"
                                 Grid.Row="0"
                                 CreditsText="2 Credits"
                                 MoreClicked="Header_MoreClicked"
                                 MoveClicked="Header_MoveClicked"
                                 MinimizeClicked="Header_MinimizeClicked"
                                 CloseClicked="Header_CloseClicked"
                                 HeaderBackground="#E7EBF3"/>

            <Border Grid.Row="1" Padding="10,9,10,10" Background="White" CornerRadius="0,0,20,20">
                <StackPanel>
                    <Border Background="#EEF2F8" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="6" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="White" CornerRadius="8" BorderBrush="#D6DCE7" BorderThickness="1" Padding="8,8">
                                <TextBlock Text="Create" HorizontalAlignment="Center" Foreground="#1F2937" FontSize="14" FontWeight="SemiBold"/>
                            </Border>
                            <Border Grid.Column="1" Background="Transparent" CornerRadius="8" Padding="8,8" Cursor="Hand" MouseLeftButtonDown="PastSessionsTab_Click">
                                <TextBlock Text="Past Sessions" HorizontalAlignment="Center" Foreground="#334155" FontSize="14" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="14" Padding="12">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Select Session Type" Foreground="#334155" FontSize="17" FontWeight="SemiBold"/>
                                <Border Width="20"
                                        Height="20"
                                        CornerRadius="10"
                                        BorderBrush="#94A3B8"
                                        BorderThickness="1"
                                        Margin="8,1,0,0"
                                        ToolTipService.ShowDuration="60000">
                                    <Border.ToolTip>
                                        <ToolTip Style="{StaticResource DarkTooltipStyle}"
                                                 Content="Choose the type of session to start. Free sessions are limited to 10 minutes and have a cooldown between sessions."/>
                                    </Border.ToolTip>
                                    <TextBlock Text="i" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#64748B" FontWeight="Bold" FontSize="12"/>
                                </Border>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Margin="0,0,6,0"
                                        CornerRadius="10"
                                        BorderBrush="#CBD5E1"
                                        BorderThickness="1"
                                        Background="White"
                                        Padding="10"
                                        MouseLeftButtonDown="FreeSession_Click"
                                        Cursor="Hand"
                                        ToolTipService.ShowDuration="60000">
                                    <Border.ToolTip>
                                        <ToolTip Style="{StaticResource DarkTooltipStyle}"
                                                 Content="A free session will not use any of your interview credits, but is limited to 10 minutes. You won't be able to create another free session for the next 12 minutes."/>
                                    </Border.ToolTip>
                                    <TextBlock Text="Free session" HorizontalAlignment="Center" Foreground="#334155" FontSize="13.5" FontWeight="SemiBold"/>
                                </Border>
                                <Border Grid.Column="1"
                                        Margin="6,0,0,0"
                                        CornerRadius="10"
                                        Padding="10"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="FullSession_Click"
                                        ToolTipService.ShowDuration="60000">
                                    <Border.ToolTip>
                                        <ToolTip Style="{StaticResource DarkTooltipStyle}"
                                                 Content="Paid sessions don't spend credits on creation. Activating a session will use 0.5 of your interview credits."/>
                                    </Border.ToolTip>
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                            <GradientStop Color="#0F172A" Offset="0"/>
                                            <GradientStop Color="#27364F" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="Full session" HorizontalAlignment="Center" Foreground="White" FontSize="13.5" FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Popup x:Name="MoreOptionsPopup"
                   Placement="Bottom"
                   VerticalOffset="8"
                   HorizontalOffset="-6"
                   StaysOpen="True"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
                <Border MinWidth="272"
                        MaxWidth="340"
                        Background="#FFFFFF"
                        CornerRadius="16"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        Padding="0"
                        SnapsToDevicePixels="True">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="24" ShadowDepth="3" Direction="270" Opacity="0.12" Color="#0F172A"/>
                    </Border.Effect>
                    <StackPanel Margin="4,6,4,8">
                        <Border Style="{StaticResource MenuRowButton}" CornerRadius="12,12,0,0" MouseLeftButtonDown="MenuDashboard_Click">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="ViewDashboard" Width="20" Height="20" Foreground="#334155" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="Dashboard" FontSize="14.5" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Height="1" Background="#E2E8F0" Margin="14,0"/>
                        <Border Style="{StaticResource MenuRowButton}" Padding="14,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="Transparent" MouseLeftButtonDown="MenuNextScreen_Click">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Next Screen" FontSize="14" Foreground="#334155" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <Border Width="18" Height="18" CornerRadius="9" BorderBrush="#94A3B8" BorderThickness="1" Background="Transparent">
                                            <TextBlock Text="i" FontSize="11" FontWeight="Bold" Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource MenuTinyIconBtn}" Width="32" Height="32" MouseLeftButtonDown="MenuNextScreenArrow_Click">
                                    <iconPacks:PackIconMaterial Kind="ChevronRight" Width="16" Height="16" Foreground="#475569" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                        <Border Height="1" Background="#E2E8F0" Margin="14,0"/>
                        <Border Padding="14,12,14,14" Background="Transparent">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Zoom" FontSize="14" FontWeight="SemiBold" Foreground="#475569" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Border Style="{StaticResource MenuTinyIconBtn}" Margin="0,0,6,0" MouseLeftButtonDown="MenuZoomPlus_Click">
                                        <iconPacks:PackIconMaterial Kind="Plus" Width="16" Height="16" Foreground="#475569" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Style="{StaticResource MenuTinyIconBtn}" Margin="0,0,6,0" MouseLeftButtonDown="MenuZoomMinus_Click">
                                        <iconPacks:PackIconMaterial Kind="Minus" Width="16" Height="16" Foreground="#475569" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Style="{StaticResource MenuTinyIconBtn}" MouseLeftButtonDown="MenuZoomReset_Click">
                                        <iconPacks:PackIconMaterial Kind="Refresh" Width="15" Height="15" Foreground="#475569" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Height="1" Background="#E2E8F0" Margin="14,6,14,0"/>
                        <Border Style="{StaticResource MenuRowDanger}" MouseLeftButtonDown="MenuLogout_Click">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Logout" Width="20" Height="20" Foreground="#DC2626" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="Logout" FontSize="14.5" FontWeight="SemiBold" Foreground="#DC2626" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Popup>

            <Popup x:Name="MoveOptionsPopup"
                   Placement="Bottom"
                   VerticalOffset="6"
                   HorizontalOffset="-78"
                   StaysOpen="True"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
                <Border Background="#FFFFFF"
                        CornerRadius="14"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        Padding="12"
                        SnapsToDevicePixels="True">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="2" Direction="270" Opacity="0.14" Color="#0F172A"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource MoveSlotBtn}" MouseLeftButtonDown="MoveTopLeft_Click"><iconPacks:PackIconMaterial Kind="ArrowTopLeft" Width="20" Height="20" Foreground="#334155" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                        <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource MoveSlotBtn}" MouseLeftButtonDown="MoveTopCenter_Click"><iconPacks:PackIconMaterial Kind="ArrowUp" Width="20" Height="20" Foreground="#334155" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                        <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource MoveSlotBtn}" MouseLeftButtonDown="MoveTopRight_Click"><iconPacks:PackIconMaterial Kind="ArrowTopRight" Width="20" Height="20" Foreground="#334155" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource MoveSlotBtn}" MouseLeftButtonDown="MoveBottomLeft_Click"><iconPacks:PackIconMaterial Kind="ArrowBottomLeft" Width="20" Height="20" Foreground="#334155" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource MoveSlotBtn}" MouseLeftButtonDown="MoveBottomCenter_Click"><iconPacks:PackIconMaterial Kind="ArrowDown" Width="20" Height="20" Foreground="#334155" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                        <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource MoveSlotBtn}" MouseLeftButtonDown="MoveBottomRight_Click"><iconPacks:PackIconMaterial Kind="ArrowBottomRight" Width="20" Height="20" Foreground="#334155" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                    </Grid>
                </Border>
            </Popup>
        </Grid>
    </Border>
</UserControl>
