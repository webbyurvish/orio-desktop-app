<UserControl x:Class="AiInterviewAssistant.SessionSetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:local="clr-namespace:AiInterviewAssistant"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="Transparent"
             FontFamily="Segoe UI">

    <Border Style="{StaticResource OrioShellCardBorder}"
            Width="520"
            MinHeight="180"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <local:AppHeaderView x:Name="SharedHeader"
                                 Grid.Row="0"
                                 CreditsText="{Binding CreditsText, Source={x:Static local:CreditsState.Current}}"
                                 MoreClicked="Header_MoreClicked"
                                 MoveClicked="Header_MoveClicked"
                                 MinimizeClicked="Header_MinimizeClicked"
                                 CloseClicked="Header_CloseClicked"/>

            <Border Grid.Row="1" Style="{StaticResource OrioShellBodyBorder}">
                <StackPanel>
                    <Border Style="{StaticResource OrioTabSwitcherBarBorder}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource OrioTabSegmentSelected}">
                                <TextBlock Text="Create" HorizontalAlignment="Center" Foreground="{StaticResource OrioTextBrush}" FontSize="13" FontWeight="SemiBold"/>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource OrioTabSegmentIdle}" MouseLeftButtonDown="PastSessionsTab_Click">
                                <TextBlock Text="Past Sessions" HorizontalAlignment="Center" Foreground="{StaticResource OrioMutedBrush}" FontSize="13" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource OrioInnerFormPanelBorder}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Select Session Type" Foreground="{StaticResource OrioTextBrush}" FontSize="15" FontWeight="SemiBold"/>
                                <Border Style="{StaticResource OrioInfoHintBorder}" Margin="8,1,0,0">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                                       Text="Choose the type of session to start. Free sessions are limited to 10 minutes and include a cooldown before you can start another. Full sessions use credits when you activate them."/>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Style="{StaticResource OrioInfoHintGlyph}"/>
                                </Border>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Margin="0,0,6,0"
                                        Style="{StaticResource OrioSessionTileFreeStyle}"
                                        MouseLeftButtonDown="FreeSession_Click"
                                        ToolTipService.ShowDuration="60000">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                                       Text="No credits are used to create a free session. It runs up to 10 minutes. After it ends, you must wait 12 minutes before starting another free session."/>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Text="Free session" HorizontalAlignment="Center" Foreground="{StaticResource OrioTextBrush}" FontSize="13" FontWeight="SemiBold"/>
                                </Border>
                                <Border Grid.Column="1"
                                        Margin="6,0,0,0"
                                        Style="{StaticResource OrioSessionTileFullStyle}"
                                        MouseLeftButtonDown="FullSession_Click"
                                        ToolTipService.ShowDuration="60000">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                                       Text="Creating a full session does not spend credits. When you activate the interview, 0.5 credit is used for the first block of time; the session can auto-extend near the end."/>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Text="Full session" HorizontalAlignment="Center" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Popup x:Name="MoreOptionsPopup"
                   Placement="Bottom"
                   VerticalOffset="8"
                   HorizontalOffset="-6"
                   StaysOpen="True"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
                <Border Style="{StaticResource OrioPopupShell}" MinWidth="220" MaxWidth="260" Padding="0">
                    <StackPanel Margin="4,4,4,4">
                        <Border Style="{StaticResource OrioPopupEmailChip}"
                                Visibility="{Binding HasEmail, Source={x:Static local:DesktopUserState.Current}, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding Email, Source={x:Static local:DesktopUserState.Current}}"
                                       FontSize="12.5"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource OrioTextBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                        </Border>
                        <Border Height="1" Background="{StaticResource OrioBorderSubtleBrush}" Margin="0,0,0,6"/>
                        <Border Style="{StaticResource MenuRowButton}" CornerRadius="10,10,0,0" MouseLeftButtonDown="MenuDashboard_Click">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="ViewDashboard" Width="18" Height="18" Foreground="#CBD5E1" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Dashboard" FontSize="13.5" FontWeight="SemiBold" Foreground="{StaticResource OrioTextBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Height="1" Background="{StaticResource OrioBorderSubtleBrush}" Margin="0,6,0,0"
                                Visibility="{Binding HasEmail, Source={x:Static local:DesktopUserState.Current}, Converter={StaticResource BoolToVis}}"/>
                        <Border Style="{StaticResource MenuRowDanger}" CornerRadius="0,0,10,10" MouseLeftButtonDown="MenuLogout_Click"
                                Visibility="{Binding HasEmail, Source={x:Static local:DesktopUserState.Current}, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Logout" Width="18" Height="18" Foreground="#F87171" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Logout" FontSize="13.5" FontWeight="SemiBold" Foreground="#FCA5A5" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Popup>

            <Popup x:Name="MoveOptionsPopup"
                   Placement="Bottom"
                   VerticalOffset="6"
                   HorizontalOffset="-78"
                   StaysOpen="True"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
                <Border Style="{StaticResource OrioPopupShell}" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource OrioMoveSlotBtnStyle}" MouseLeftButtonDown="MoveTopLeft_Click">
                            <iconPacks:PackIconMaterial Kind="ArrowTopLeft" Width="17" Height="17" Foreground="#CBD5E1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource OrioMoveSlotBtnStyle}" MouseLeftButtonDown="MoveTopCenter_Click">
                            <iconPacks:PackIconMaterial Kind="ArrowUp" Width="17" Height="17" Foreground="#CBD5E1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource OrioMoveSlotBtnStyle}" MouseLeftButtonDown="MoveTopRight_Click">
                            <iconPacks:PackIconMaterial Kind="ArrowTopRight" Width="17" Height="17" Foreground="#CBD5E1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource OrioMoveSlotBtnStyle}" MouseLeftButtonDown="MoveBottomLeft_Click">
                            <iconPacks:PackIconMaterial Kind="ArrowBottomLeft" Width="17" Height="17" Foreground="#CBD5E1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource OrioMoveSlotBtnStyle}" MouseLeftButtonDown="MoveBottomCenter_Click">
                            <iconPacks:PackIconMaterial Kind="ArrowDown" Width="17" Height="17" Foreground="#CBD5E1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource OrioMoveSlotBtnStyle}" MouseLeftButtonDown="MoveBottomRight_Click">
                            <iconPacks:PackIconMaterial Kind="ArrowBottomRight" Width="17" Height="17" Foreground="#CBD5E1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
            </Popup>
        </Grid>
    </Border>
</UserControl>
