<UserControl x:Class="AiInterviewAssistant.CreateSessionDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:local="clr-namespace:AiInterviewAssistant"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="Transparent"
             FontFamily="Segoe UI">

    <Border Style="{StaticResource OrioShellCardBorder}"
            Width="520"
            MinHeight="180"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <local:AppHeaderView x:Name="SharedHeader"
                                 Grid.Row="0"
                                 CreditsText="{Binding CreditsText, Source={x:Static local:CreditsState.Current}}"
                                 MoreClicked="Header_MoreClicked"
                                 MoveClicked="Header_MoveClicked"
                                 MinimizeClicked="Header_MinimizeClicked"
                                 CloseClicked="Header_CloseClicked"/>

            <Border Grid.Row="1" Style="{StaticResource OrioShellBodyBorder}">
                <StackPanel>
                    <Border Style="{StaticResource OrioTabSwitcherBarBorder}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource OrioTabSegmentSelected}">
                                <TextBlock Text="Create" HorizontalAlignment="Center" Foreground="{StaticResource OrioTextBrush}" FontSize="13" FontWeight="SemiBold"/>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource OrioTabSegmentIdle}" MouseLeftButtonDown="PastSessionsTab_Click">
                                <TextBlock Text="Past Sessions" HorizontalAlignment="Center" Foreground="{StaticResource OrioMutedBrush}" FontSize="13" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource OrioInnerFormPanelBorder}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="Company" Foreground="{StaticResource OrioTextBrush}" FontSize="15" FontWeight="SemiBold"/>
                                <Border Style="{StaticResource OrioInfoHintBorder}" Margin="7,0,0,0">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                                       Text="The company you are interviewing with. Used to tailor answers and context to that employer."/>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Style="{StaticResource OrioInfoHintGlyph}"/>
                                </Border>
                            </StackPanel>
                            <Border Style="{StaticResource OrioFieldHostBorder}" Margin="0,0,0,10">
                                <TextBox x:Name="CompanyTextBox"
                                         Style="{StaticResource OrioFormTextBoxStyle}"
                                         Text="">
                                    <TextBox.ToolTip>
                                        <ToolTip>
                                            <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                                       Text="Type or paste the company name as you want it referenced in AI answers (e.g. official brand name)."/>
                                        </ToolTip>
                                    </TextBox.ToolTip>
                                </TextBox>
                            </Border>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="Job Description" Foreground="{StaticResource OrioTextBrush}" FontSize="15" FontWeight="SemiBold"/>
                                <Border Style="{StaticResource OrioInfoHintBorder}" Margin="7,0,0,0">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                                       Text="Paste the job description or key requirements. The assistant uses this to stay aligned with the role and stack."/>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Style="{StaticResource OrioInfoHintGlyph}"/>
                                </Border>
                            </StackPanel>
                            <Border Style="{StaticResource OrioFieldHostBorder}" Margin="0,0,0,10">
                                <TextBox x:Name="JobDescriptionTextBox"
                                         Style="{StaticResource OrioFormMultilineTextBoxStyle}"
                                         Text=""
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         MinHeight="74"
                                         MaxHeight="120">
                                    <TextBox.ToolTip>
                                        <ToolTip>
                                            <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                                       Text="Include responsibilities, tech stack, and seniority. More detail usually yields more relevant interview answers."/>
                                        </ToolTip>
                                    </TextBox.ToolTip>
                                </TextBox>
                            </Border>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="Resume" Foreground="{StaticResource OrioTextBrush}" FontSize="15" FontWeight="SemiBold"/>
                                <Border Style="{StaticResource OrioInfoHintBorder}" Margin="7,0,0,0">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                                       Text="Pick the resume stored in your account. Answers can reference your experience, skills, and projects from that profile."/>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Style="{StaticResource OrioInfoHintGlyph}"/>
                                </Border>
                            </StackPanel>
                            <ComboBox x:Name="ResumeComboBox"
                                      Style="{StaticResource OrioComboBoxStyle}"
                                      Margin="0,0,0,4"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Id"
                                      HorizontalContentAlignment="Stretch">
                                <ComboBox.ToolTip>
                                    <ToolTip>
                                        <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                                   Text="If the list is empty, add or sync resumes from your dashboard. The selected resume grounds AI answers in your real background."/>
                                    </ToolTip>
                                </ComboBox.ToolTip>
                            </ComboBox>
                            <TextBlock x:Name="ResumeLoadStatusText"
                                       Margin="2,0,0,12"
                                       FontSize="11.5"
                                       Foreground="{StaticResource OrioMutedBrush}"
                                       Text=""/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource OrioOutlineSecondaryBtn}" Margin="0,0,6,0" MouseLeftButtonDown="Back_Click">
                                    <TextBlock Text="Back" Foreground="#A5B4FC" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                </Border>
                                <Border Grid.Column="1" CornerRadius="9" Padding="9,8" Margin="6,0,0,0" Cursor="Hand" MouseLeftButtonDown="Next_Click">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                            <GradientStop Color="#0D9488" Offset="0"/>
                                            <GradientStop Color="#6366F1" Offset="0.55"/>
                                            <GradientStop Color="#7C3AED" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="Next" Foreground="White" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Popup x:Name="MoreOptionsPopup" Placement="Bottom" VerticalOffset="8" HorizontalOffset="-6" StaysOpen="True" AllowsTransparency="True" PopupAnimation="Fade">
                <Border Style="{StaticResource OrioPopupShell}" MinWidth="220" MaxWidth="260" Padding="0">
                    <StackPanel Margin="4,4,4,4">
                        <Border Style="{StaticResource OrioPopupEmailChip}"
                                Visibility="{Binding HasEmail, Source={x:Static local:DesktopUserState.Current}, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding Email, Source={x:Static local:DesktopUserState.Current}}"
                                       FontSize="12.5"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource OrioTextBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                        </Border>
                        <Border Height="1" Background="{StaticResource OrioBorderSubtleBrush}" Margin="0,0,0,6"/>
                        <Border Style="{StaticResource MenuRowButton}" CornerRadius="10,10,0,0" MouseLeftButtonDown="MenuDashboard_Click">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="ViewDashboard" Width="18" Height="18" Foreground="#CBD5E1" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Dashboard" FontSize="13.5" FontWeight="SemiBold" Foreground="{StaticResource OrioTextBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Height="1" Background="{StaticResource OrioBorderSubtleBrush}" Margin="0,6,0,0"
                                Visibility="{Binding HasEmail, Source={x:Static local:DesktopUserState.Current}, Converter={StaticResource BoolToVis}}"/>
                        <Border Style="{StaticResource MenuRowDanger}" CornerRadius="0,0,10,10" MouseLeftButtonDown="MenuLogout_Click"
                                Visibility="{Binding HasEmail, Source={x:Static local:DesktopUserState.Current}, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Logout" Width="18" Height="18" Foreground="#F87171" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Logout" FontSize="13.5" FontWeight="SemiBold" Foreground="#FCA5A5" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Popup>

            <Popup x:Name="MoveOptionsPopup" Placement="Bottom" VerticalOffset="6" HorizontalOffset="-78" StaysOpen="True" AllowsTransparency="True" PopupAnimation="Fade">
                <Border Style="{StaticResource OrioPopupShell}" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource OrioMoveSlotBtnStyle}" MouseLeftButtonDown="MoveTopLeft_Click"><iconPacks:PackIconMaterial Kind="ArrowTopLeft" Width="17" Height="17" Foreground="#CBD5E1" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                        <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource OrioMoveSlotBtnStyle}" MouseLeftButtonDown="MoveTopCenter_Click"><iconPacks:PackIconMaterial Kind="ArrowUp" Width="17" Height="17" Foreground="#CBD5E1" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                        <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource OrioMoveSlotBtnStyle}" MouseLeftButtonDown="MoveTopRight_Click"><iconPacks:PackIconMaterial Kind="ArrowTopRight" Width="17" Height="17" Foreground="#CBD5E1" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource OrioMoveSlotBtnStyle}" MouseLeftButtonDown="MoveBottomLeft_Click"><iconPacks:PackIconMaterial Kind="ArrowBottomLeft" Width="17" Height="17" Foreground="#CBD5E1" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource OrioMoveSlotBtnStyle}" MouseLeftButtonDown="MoveBottomCenter_Click"><iconPacks:PackIconMaterial Kind="ArrowDown" Width="17" Height="17" Foreground="#CBD5E1" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                        <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource OrioMoveSlotBtnStyle}" MouseLeftButtonDown="MoveBottomRight_Click"><iconPacks:PackIconMaterial Kind="ArrowBottomRight" Width="17" Height="17" Foreground="#CBD5E1" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                    </Grid>
                </Border>
            </Popup>
        </Grid>
    </Border>
</UserControl>
