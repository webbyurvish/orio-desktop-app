<UserControl x:Class="AiInterviewAssistant.CreateSessionStep2View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:local="clr-namespace:AiInterviewAssistant"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="Transparent"
             FontFamily="Segoe UI">

    <Border Style="{StaticResource OrioShellCardBorder}"
            Width="520"
            MinHeight="180"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

            <local:AppHeaderView x:Name="SharedHeader" Grid.Row="0" CreditsText="{Binding CreditsText, Source={x:Static local:CreditsState.Current}}"
                                 MoreClicked="Header_MoreClicked" MoveClicked="Header_MoveClicked"
                                 MinimizeClicked="Header_MinimizeClicked" CloseClicked="Header_CloseClicked"/>

            <Border Grid.Row="1" Style="{StaticResource OrioShellBodyBorder}">
                <StackPanel>
                    <Border Style="{StaticResource OrioTabSwitcherBarBorder}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource OrioTabSegmentSelected}">
                                <TextBlock Text="Create" HorizontalAlignment="Center" Foreground="{StaticResource OrioTextBrush}" FontSize="13" FontWeight="SemiBold"/>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource OrioTabSegmentIdle}" MouseLeftButtonDown="PastSessionsTab_Click">
                                <TextBlock Text="Past Sessions" HorizontalAlignment="Center" Foreground="{StaticResource OrioMutedBrush}" FontSize="13" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource OrioInnerFormPanelBorder}">
                        <StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Language" Foreground="{StaticResource OrioTextBrush}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <Border Style="{StaticResource OrioInfoHintBorder}" Margin="7,0,0,0" VerticalAlignment="Center">
                                        <Border.ToolTip>
                                            <ToolTip>
                                                <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                                           Text="Language used for transcription and for AI answers in this session. Pick the language you and the interviewer mainly use."/>
                                            </ToolTip>
                                        </Border.ToolTip>
                                        <TextBlock Style="{StaticResource OrioInfoHintGlyph}"/>
                                    </Border>
                                </StackPanel>
                                <ComboBox x:Name="LanguageComboBox" Style="{StaticResource OrioComboBoxStyle}" SelectedIndex="0" Margin="0,0,0,12">
                                    <ComboBox.ToolTip>
                                        <ToolTip>
                                            <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                                       Text="Applies to speech recognition and AI answer language."/>
                                        </ToolTip>
                                    </ComboBox.ToolTip>
                                </ComboBox>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Simple Language" Foreground="{StaticResource OrioTextBrush}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <Border Style="{StaticResource OrioInfoHintBorder}" Margin="7,0,0,0" VerticalAlignment="Center">
                                            <Border.ToolTip>
                                                <ToolTip>
                                                    <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                                               Text="When on, answers use shorter sentences and plainer words—useful if you want easy-to-say replies in the interview."/>
                                                </ToolTip>
                                            </Border.ToolTip>
                                            <TextBlock Style="{StaticResource OrioInfoHintGlyph}"/>
                                        </Border>
                                    </StackPanel>
                                    <ToggleButton x:Name="SimpleLanguageToggle" Grid.Column="1" Style="{StaticResource OrioSwitchToggleStyle}" VerticalAlignment="Center" IsChecked="True">
                                        <ToggleButton.ToolTip>
                                            <ToolTip>
                                                <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                                           Text="Toggle simpler vocabulary and structure for generated answers."/>
                                            </ToolTip>
                                        </ToggleButton.ToolTip>
                                    </ToggleButton>
                                </Grid>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Natural mode" Foreground="{StaticResource OrioTextBrush}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <Border Style="{StaticResource OrioInfoHintBorder}" Margin="7,0,0,0" VerticalAlignment="Center">
                                            <Border.ToolTip>
                                                <ToolTip>
                                                    <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                                               Text="When on, answers sound like natural speech—thinking out loud, conversational—so they are easier to say in a live interview without sounding like you are reading an AI script."/>
                                                </ToolTip>
                                            </Border.ToolTip>
                                            <TextBlock Style="{StaticResource OrioInfoHintGlyph}"/>
                                        </Border>
                                    </StackPanel>
                                    <ToggleButton x:Name="NaturalSpeakingModeToggle" Grid.Column="1" Style="{StaticResource OrioSwitchToggleStyle}" VerticalAlignment="Center" IsChecked="False">
                                        <ToggleButton.ToolTip>
                                            <ToolTip>
                                                <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                                           Text="More human, spoken tone for suggested answers (recommended for live interviews)."/>
                                            </ToolTip>
                                        </ToggleButton.ToolTip>
                                    </ToggleButton>
                                </Grid>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="Extra Context/Instructions" Foreground="{StaticResource OrioTextBrush}" FontSize="15" FontWeight="SemiBold"/>
                                <Border Style="{StaticResource OrioInfoHintBorder}" Margin="7,0,0,0">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                                       Text="Steers tone and content: e.g. be concise, include code, sound confident, or match a seniority level. This is sent with every AI answer request."/>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Style="{StaticResource OrioInfoHintGlyph}"/>
                                </Border>
                            </StackPanel>
                            <Border Style="{StaticResource OrioFieldHostBorder}" Margin="0,0,0,10">
                                <Grid>
                                    <TextBox x:Name="ExtraContextTextBox"
                                             Text=""
                                             Style="{StaticResource OrioFormMultilineTextBoxStyle}"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             MinHeight="54"
                                             MaxHeight="72"
                                             TextChanged="ExtraContextTextBox_TextChanged">
                                        <TextBox.ToolTip>
                                            <ToolTip>
                                                <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                                           Text="Edit this anytime before or during the session. Keep instructions concrete (length, examples, style) for best results."/>
                                            </ToolTip>
                                        </TextBox.ToolTip>
                                    </TextBox>
                                    <TextBlock x:Name="ExtraContextPlaceholder"
                                               Text="e.g. Be concise, include a short code example when helpful, match seniority level…"
                                               Padding="10,8"
                                               FontSize="13"
                                               FontStyle="Italic"
                                               Foreground="#64748B"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Top"
                                               IsHitTestVisible="False"/>
                                </Grid>
                            </Border>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Auto Generate AI Response" Foreground="{StaticResource OrioTextBrush}" FontSize="15" FontWeight="SemiBold"/>
                                    <Border Style="{StaticResource OrioInfoHintBorder}" Margin="7,0,0,0">
                                        <Border.ToolTip>
                                            <ToolTip>
                                                <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                                           Text="When on, the main interview window can detect questions from audio and stream suggested answers. Turn off if you only want manual “AI Answer”."/>
                                            </ToolTip>
                                        </Border.ToolTip>
                                        <TextBlock Style="{StaticResource OrioInfoHintGlyph}"/>
                                    </Border>
                                </StackPanel>
                                <ToggleButton Grid.Column="1" Style="{StaticResource OrioSwitchToggleStyle}" IsChecked="True">
                                    <ToggleButton.ToolTip>
                                        <ToolTip>
                                            <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                                       Text="Matches the “Auto answer” behavior in the live session toolbar after you start the interview."/>
                                        </ToolTip>
                                    </ToggleButton.ToolTip>
                                </ToggleButton>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Save Transcript" Foreground="{StaticResource OrioTextBrush}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <Border Style="{StaticResource OrioInfoHintBorder}" Margin="7,0,0,0" VerticalAlignment="Center">
                                        <Border.ToolTip>
                                            <ToolTip>
                                                <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                                           Text="When enabled, conversation text from the session can be stored in your account for review (subject to your plan and privacy settings)."/>
                                            </ToolTip>
                                        </Border.ToolTip>
                                        <TextBlock Style="{StaticResource OrioInfoHintGlyph}"/>
                                    </Border>
                                </StackPanel>
                                <ToggleButton x:Name="SaveTranscriptToggle" Grid.Column="1" Style="{StaticResource OrioSwitchToggleStyle}">
                                    <ToggleButton.ToolTip>
                                        <ToolTip>
                                            <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                                       Text="Turn on to keep a transcript; turn off if you prefer not to persist this session’s dialogue."/>
                                        </ToolTip>
                                    </ToggleButton.ToolTip>
                                </ToggleButton>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="1.2*"/></Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource OrioOutlineSecondaryBtn}" Margin="0,0,6,0" MouseLeftButtonDown="Back_Click">
                                    <TextBlock Text="Back" Foreground="#A5B4FC" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                </Border>
                                <Border Grid.Column="1" CornerRadius="9" Padding="9,8" Cursor="Hand" MouseLeftButtonDown="CreateSession_Click" Margin="6,0,0,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                            <GradientStop Color="#0D9488" Offset="0"/>
                                            <GradientStop Color="#6366F1" Offset="0.55"/>
                                            <GradientStop Color="#7C3AED" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock x:Name="CreateSessionButtonText" Text="Create Free Session" Foreground="White" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Popup x:Name="MoreOptionsPopup" Placement="Bottom" VerticalOffset="8" HorizontalOffset="-6" StaysOpen="True" AllowsTransparency="True" PopupAnimation="Fade">
                <Border Style="{StaticResource OrioPopupShell}" MinWidth="220" MaxWidth="260" Padding="0">
                    <StackPanel Margin="4,4,4,4">
                        <Border Style="{StaticResource OrioPopupEmailChip}"
                                Visibility="{Binding HasEmail, Source={x:Static local:DesktopUserState.Current}, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding Email, Source={x:Static local:DesktopUserState.Current}}"
                                       FontSize="12.5"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource OrioTextBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                        </Border>
                        <Border Height="1" Background="{StaticResource OrioBorderSubtleBrush}" Margin="0,0,0,6"/>
                        <Border Style="{StaticResource MenuRowButton}" CornerRadius="10,10,0,0" MouseLeftButtonDown="MenuDashboard_Click">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="ViewDashboard" Width="18" Height="18" Foreground="#CBD5E1" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Dashboard" FontSize="13.5" FontWeight="SemiBold" Foreground="{StaticResource OrioTextBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Height="1" Background="{StaticResource OrioBorderSubtleBrush}" Margin="0,6,0,0"
                                Visibility="{Binding HasEmail, Source={x:Static local:DesktopUserState.Current}, Converter={StaticResource BoolToVis}}"/>
                        <Border Style="{StaticResource MenuRowDanger}" CornerRadius="0,0,10,10" MouseLeftButtonDown="MenuLogout_Click"
                                Visibility="{Binding HasEmail, Source={x:Static local:DesktopUserState.Current}, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Logout" Width="18" Height="18" Foreground="#F87171" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Logout" FontSize="13.5" FontWeight="SemiBold" Foreground="#FCA5A5" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Popup>

            <Popup x:Name="MoveOptionsPopup" Placement="Bottom" VerticalOffset="6" HorizontalOffset="-78" StaysOpen="True" AllowsTransparency="True" PopupAnimation="Fade">
                <Border Style="{StaticResource OrioPopupShell}" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource OrioMoveSlotBtnStyle}" MouseLeftButtonDown="MoveTopLeft_Click"><iconPacks:PackIconMaterial Kind="ArrowTopLeft" Width="17" Height="17" Foreground="#CBD5E1" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                        <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource OrioMoveSlotBtnStyle}" MouseLeftButtonDown="MoveTopCenter_Click"><iconPacks:PackIconMaterial Kind="ArrowUp" Width="17" Height="17" Foreground="#CBD5E1" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                        <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource OrioMoveSlotBtnStyle}" MouseLeftButtonDown="MoveTopRight_Click"><iconPacks:PackIconMaterial Kind="ArrowTopRight" Width="17" Height="17" Foreground="#CBD5E1" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource OrioMoveSlotBtnStyle}" MouseLeftButtonDown="MoveBottomLeft_Click"><iconPacks:PackIconMaterial Kind="ArrowBottomLeft" Width="17" Height="17" Foreground="#CBD5E1" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource OrioMoveSlotBtnStyle}" MouseLeftButtonDown="MoveBottomCenter_Click"><iconPacks:PackIconMaterial Kind="ArrowDown" Width="17" Height="17" Foreground="#CBD5E1" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                        <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource OrioMoveSlotBtnStyle}" MouseLeftButtonDown="MoveBottomRight_Click"><iconPacks:PackIconMaterial Kind="ArrowBottomRight" Width="17" Height="17" Foreground="#CBD5E1" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                    </Grid>
                </Border>
            </Popup>
        </Grid>
    </Border>
</UserControl>
