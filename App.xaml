<Application x:Class="AiInterviewAssistant.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:AiInterviewAssistant"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="SharedDesktopChrome.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style TargetType="ToolTip" BasedOn="{StaticResource OrioTooltipStyle}"/>

            <Style x:Key="MenuRowDanger" TargetType="Border">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Padding" Value="14,12"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="CornerRadius" Value="0,0,12,12"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#FEF2F2"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
