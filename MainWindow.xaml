<Window x:Class="AiInterviewAssistant.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AiInterviewAssistant"
        Title="Orio AI"
        Width="720" MinHeight="200"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        FocusVisualStyle="{x:Null}"
        Loaded="Window_Loaded"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <!-- Shared chrome button chrome -->
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Background" Value="#2A2A3A"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#4B5563"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ClearButtonStyle" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Background" Value="#374151"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#6B7280"/>
        </Style>
        <!-- Compact row actions: smaller chrome, slightly larger readable type -->
        <Style x:Key="CompactActionButtonBase" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="MaxHeight" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.93"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.86"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CompactClearButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactActionButtonBase}">
            <Setter Property="Background" Value="#374151"/>
            <Setter Property="Foreground" Value="#F3F4F6"/>
            <Setter Property="BorderBrush" Value="#6B7280"/>
            <Setter Property="MinWidth" Value="56"/>
        </Style>
        <Style x:Key="CompactPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactActionButtonBase}">
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#6D28D9"/>
            <Setter Property="MinWidth" Value="84"/>
        </Style>
        <Style x:Key="CompactAskButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactActionButtonBase}">
            <Setter Property="Background" Value="#0D9488"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#0F766E"/>
            <Setter Property="MinWidth" Value="52"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#6D28D9"/>
        </Style>
        <Style x:Key="AskButtonStyle" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Background" Value="#0D9488"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#0F766E"/>
        </Style>
        <Style x:Key="CloseIconButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Background" Value="#27272A"/>
            <Setter Property="Foreground" Value="#A1A1AA"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Content" Value="✕"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#52525B"/>
        </Style>
        <Style x:Key="MainWindowCloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="BorderBrush" Value="#B91C1C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EF4444"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#B91C1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="EndSessionToolbarStyle" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#EA580C"/>
            <Setter Property="BorderBrush" Value="#C2410C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F97316"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#C2410C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HideToolbarButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="52"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#4F46E5"/>
            <Setter Property="BorderBrush" Value="#4338CA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#6366F1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#4338CA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ToolbarIconCircleStyle" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- iOS-style switch; use empty Content — label sits beside control in toolbar -->
        <Style x:Key="AutoAnswerSwitchToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Content" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Width="42" Height="22" SnapsToDevicePixels="True">
                            <Border x:Name="Track" CornerRadius="11" Height="22"
                                    Background="#3F3F46" BorderBrush="#52525B" BorderThickness="1"/>
                            <Border x:Name="Thumb" Width="18" Height="18" CornerRadius="9"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Margin="3,0,0,0" Background="#FAFAFA" BorderBrush="#D4D4D8" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="3" ShadowDepth="1" Direction="270" Opacity="0.25" Color="#000000"/>
                                </Border.Effect>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#059669"/>
                                <Setter TargetName="Track" Property="BorderBrush" Value="#047857"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ChromeSliderStyle" TargetType="Slider">
            <Setter Property="Height" Value="20"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Foreground" Value="#818CF8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}"/>
                            </Grid.RowDefinitions>
                            <Border x:Name="TrackBackground" Grid.Row="1" Height="5" CornerRadius="3"
                                    Background="#3F3F46" BorderThickness="0" VerticalAlignment="Center" Margin="0,0,0,0"/>
                            <Track x:Name="PART_Track" Grid.Row="1" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}" Height="0" Width="0" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}" Height="0" Width="0" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Width="16" Height="16" Focusable="False">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="#A5B4FC" Stroke="#6366F1" StrokeThickness="1.5"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AnswerNavButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="Background" Value="#4338CA"/>
            <Setter Property="BorderBrush" Value="#6366F1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="hb" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="hb" Property="Background" Value="#6366F1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="hb" Property="Background" Value="#3730A3"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#64748B"/>
                                <Setter TargetName="hb" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Black transparent scrollbar -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="Transparent">
                            <Border Background="#22000000" CornerRadius="4" Margin="2,4"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border Background="#66000000" CornerRadius="4" Margin="1,2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Startup: code sets Background transparent + SizeToContent so only the login card is visible -->
    <Border x:Name="RootChromeBorder"
            CornerRadius="12"
            Background="Transparent"
            BorderBrush="Transparent"
            BorderThickness="0"
            Padding="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="3" Direction="270" Opacity="0.16" Color="#0F172A"/>
        </Border.Effect>

        <Grid>
            <local:StartupLoginView x:Name="StartupLoginView"/>
            <local:SessionSetupView x:Name="SessionSetupView" Visibility="Collapsed"/>
            <local:PastSessionsView x:Name="PastSessionsView" Visibility="Collapsed"/>
            <local:CreateSessionDetailsView x:Name="CreateSessionDetailsView" Visibility="Collapsed"/>
            <local:CreateSessionStep2View x:Name="CreateSessionStep2View" Visibility="Collapsed"/>
            <local:ActivateSessionView x:Name="ActivateSessionView" Visibility="Collapsed"/>
            <Grid x:Name="MainContentGrid" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Top bar: left tools, centered title (fill), right controls -->
            <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="True">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center" Margin="4,0,16,0">
                    <Button x:Name="HideButton" Content="Hide"
                            Style="{StaticResource HideToolbarButtonStyle}"
                            Margin="0,0,8,0"
                            Click="HideButton_Click">
                        <Button.ToolTip>
                            <ToolTip>
                                <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                           Text="Hides this window. A small chip appears at the top center of your screen—click it to bring Orio back (same as Hide on other screens)."/>
                            </ToolTip>
                        </Button.ToolTip>
                    </Button>
                    <Button x:Name="MicToggleButton"
                            Content="&#xE720;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="13"
                            Style="{StaticResource ToolbarIconCircleStyle}"
                            Margin="0,0,8,0"
                            Background="#10B981"
                            Foreground="#FFFFFF"
                            BorderBrush="#059669"
                            Click="MicToggleButton_Click">
                        <Button.ToolTip>
                            <ToolTip>
                                <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                           Text="Microphone capture for the interview. Green: listening. Click to mute your mic when you do not want speech sent to transcription."/>
                            </ToolTip>
                        </Button.ToolTip>
                    </Button>
                    <Button x:Name="SpeakerToggleButton"
                            Content="&#xE767;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="13"
                            Style="{StaticResource ToolbarIconCircleStyle}"
                            Margin="0,0,8,0"
                            Background="#0EA5E9"
                            Foreground="#FFFFFF"
                            BorderBrush="#0284C7"
                            Click="SpeakerToggleButton_Click">
                        <Button.ToolTip>
                            <ToolTip>
                                <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                           Text="System / speaker audio (what you hear from the call). Used to capture the interviewer’s voice for transcription and auto-answer."/>
                            </ToolTip>
                        </Button.ToolTip>
                    </Button>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Auto answer"
                                   Foreground="#E4E4E7"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   FontFamily="Segoe UI"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0">
                            <TextBlock.ToolTip>
                                <ToolTip>
                                    <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                               Text="When on, Orio listens for complete questions from speaker audio and from your mic (after a short pause), then streams a suggested answer automatically."/>
                                </ToolTip>
                            </TextBlock.ToolTip>
                        </TextBlock>
                        <ToggleButton x:Name="AutoAnswerToggle"
                                      Style="{StaticResource AutoAnswerSwitchToggleStyle}"
                                      VerticalAlignment="Center"
                                      Checked="AutoAnswerToggle_Changed"
                                      Unchecked="AutoAnswerToggle_Changed">
                            <ToggleButton.ToolTip>
                                <ToolTip>
                                    <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                               Text="Turn automatic answers on or off without leaving the interview. You can still use “AI Answer” manually when this is off."/>
                                </ToolTip>
                            </ToggleButton.ToolTip>
                        </ToggleButton>
                    </StackPanel>
                </StackPanel>
                <Button Content="✕" DockPanel.Dock="Right" Margin="8,0,0,0"
                        Style="{StaticResource MainWindowCloseButtonStyle}"
                        Click="CloseButton_Click">
                    <Button.ToolTip>
                        <ToolTip>
                            <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                       Text="Closes Orio completely. End the interview session first if you want a clean shutdown."/>
                        </ToolTip>
                    </Button.ToolTip>
                </Button>
                <Button x:Name="EndSessionButton"
                        Content="⏹"
                        DockPanel.Dock="Right"
                        Margin="8,0,0,0"
                        Style="{StaticResource EndSessionToolbarStyle}"
                        Click="EndSessionButton_Click"
                        IsEnabled="False">
                    <Button.ToolTip>
                        <ToolTip>
                            <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                       Text="Stops the current interview session, timers, and streaming. Your transcript may still be saved if you enabled that when creating the session."/>
                        </ToolTip>
                    </Button.ToolTip>
                </Button>
                <Border DockPanel.Dock="Right"
                        Background="#CC18181B"
                        CornerRadius="9"
                        BorderBrush="#F59E0B"
                        BorderThickness="1"
                        Padding="10,0"
                        Height="30"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0"
                        ToolTipService.ShowDuration="60000">
                    <Border.ToolTip>
                        <ToolTip>
                            <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                       Text="Time remaining in the active interview session. The session may auto-extend shortly before it reaches zero if your plan allows it."/>
                        </ToolTip>
                    </Border.ToolTip>
                    <TextBlock x:Name="SessionTimerTextBlock"
                               Text="00:00"
                               Foreground="#FEF3C7"
                               FontWeight="SemiBold"
                               FontSize="12.5"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center"/>
                </Border>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                    <TextBlock Text="Opacity" Foreground="#CBD5E1" FontSize="11.5" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,8,0">
                        <TextBlock.ToolTip>
                            <ToolTip>
                                <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                           Text="Dims the floating panel so you can see through to the meeting app. Question text, transcript, and answers stay fully readable."/>
                            </ToolTip>
                        </TextBlock.ToolTip>
                    </TextBlock>
                    <Slider x:Name="WindowOpacitySlider"
                            Width="100"
                            Style="{StaticResource ChromeSliderStyle}"
                            Minimum="55"
                            Maximum="100"
                            Value="90"
                            ValueChanged="WindowOpacitySlider_ValueChanged"
                            VerticalAlignment="Center"
                            TickPlacement="None"
                            IsSnapToTickEnabled="False">
                        <Slider.ToolTip>
                            <ToolTip>
                                <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                           Text="Drag to make the window more transparent over the meeting. Minimum keeps the UI readable."/>
                            </ToolTip>
                        </Slider.ToolTip>
                    </Slider>
                </StackPanel>
                <TextBlock Text="Orio AI"
                           Foreground="#F8FAFC" FontWeight="SemiBold" FontSize="15" FontFamily="Segoe UI"
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           TextAlignment="Center"/>
            </DockPanel>

            <!-- Transcript area (same height as question) -->
            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Background="#9918181B" CornerRadius="10" BorderBrush="#6366F1" BorderThickness="1"
                        Margin="0,0,8,0" Height="40">
                    <TextBox x:Name="TranscriptTextBlock"
                             Background="Transparent" BorderThickness="0"
                             Foreground="#F8FAFC" TextWrapping="Wrap" FontSize="13"
                             FontFamily="Segoe UI" FontWeight="SemiBold"
                             VerticalContentAlignment="Top" Padding="10,7"
                             IsReadOnly="True" Text=""/>
                </Border>

                <Button x:Name="TranscriptClearButton" Grid.Column="1" Content="Clear" Margin="0,0,6,0"
                        Click="TranscriptClearButton_Click" Style="{StaticResource CompactClearButtonStyle}">
                    <Button.ToolTip>
                        <ToolTip>
                            <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                       Text="Clears the live transcript text in this window only. It does not delete saved history on the server."/>
                        </ToolTip>
                    </Button.ToolTip>
                </Button>
                <Button x:Name="ScreenshotAiButton" Grid.Column="2" Content="Analyze screen"
                        Click="ScreenshotAiButton_Click" Style="{StaticResource CompactAskButtonStyle}"
                        Margin="0,0,6,0" MinWidth="118">
                    <Button.ToolTip>
                        <ToolTip>
                            <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                       Text="Captures all monitors (Orio is hidden from the shot), reads text with Azure Computer Vision, then answers any interview or coding question found—using your resume and session context."/>
                        </ToolTip>
                    </Button.ToolTip>
                </Button>
                <Button x:Name="AiAnswerButton" Grid.Column="3" Content="AI Answer"
                        Click="AiAnswerButton_Click" Style="{StaticResource CompactPrimaryButtonStyle}">
                    <Button.ToolTip>
                        <ToolTip>
                            <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                       Text="Generates an answer for the latest detected or typed question using your session context (job, resume, and instructions)."/>
                        </ToolTip>
                    </Button.ToolTip>
                </Button>
            </Grid>

            <!-- Question input (same height as transcript) -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Background="#9918181B" CornerRadius="10" BorderBrush="#14B8A6" BorderThickness="1"
                        Margin="0,0,8,0" Height="40">
                    <TextBox x:Name="QuestionTextBox"
                             Background="Transparent" BorderThickness="0"
                             Foreground="#F8FAFC" TextWrapping="Wrap" FontSize="13"
                             FontFamily="Segoe UI" FontWeight="SemiBold"
                             VerticalContentAlignment="Center" Padding="10,7"
                             Text=""/>
                </Border>

                <Button x:Name="QuestionClearButton" Grid.Column="1" Content="Clear" Margin="0,0,6,0"
                        Click="QuestionClearButton_Click" Style="{StaticResource CompactClearButtonStyle}">
                    <Button.ToolTip>
                        <ToolTip>
                            <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                       Text="Clears the question box so you can type or paste a different prompt."/>
                        </ToolTip>
                    </Button.ToolTip>
                </Button>
                <Button x:Name="AskButton" Grid.Column="2" Content="Ask"
                        Click="AskButton_Click" Style="{StaticResource CompactAskButtonStyle}">
                    <Button.ToolTip>
                        <ToolTip>
                            <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                       Text="Sends the text in the question field to the AI (similar to AI Answer but driven by what you typed)."/>
                        </ToolTip>
                    </Button.ToolTip>
                </Button>
            </Grid>

            <!-- Status/debug line (always visible) -->
            <Border Grid.Row="3" Background="#9918181B" CornerRadius="10" BorderBrush="#52525B" BorderThickness="1" Padding="10,8" Margin="0,4,0,0">
                <TextBlock x:Name="StatusTextBlock"
                           Foreground="#D4D4D8" FontSize="11.5" FontFamily="Segoe UI"
                           TextWrapping="Wrap" Text="Idle"/>
            </Border>

            <!-- AI Answer section: visible only when there is an answer; no space when collapsed -->
            <Grid x:Name="AnswerSectionPanel" Grid.Row="4" Margin="0,10,0,0" Visibility="Collapsed"
                  MinHeight="120">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="AI Answer:" Foreground="#E0E7FF" FontWeight="SemiBold" FontSize="13"
                               FontFamily="Segoe UI" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,10,0">
                        <Button x:Name="AnswerHistoryPrevButton"
                                Content="‹"
                                Style="{StaticResource AnswerNavButtonStyle}"
                                Click="AnswerHistoryPrev_Click"
                                Visibility="Collapsed"
                                Margin="0,0,6,0">
                            <Button.ToolTip>
                                <ToolTip>
                                    <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                               Text="Show the previous AI answer generated in this session."/>
                                </ToolTip>
                            </Button.ToolTip>
                        </Button>
                        <TextBlock x:Name="AnswerHistoryPositionText"
                                   Foreground="#C7D2FE" FontSize="11.5" FontWeight="SemiBold"
                                   VerticalAlignment="Center" MinWidth="36" TextAlignment="Center"
                                   Visibility="Collapsed" Margin="0,0,6,0"/>
                        <Button x:Name="AnswerHistoryNextButton"
                                Content="›"
                                Style="{StaticResource AnswerNavButtonStyle}"
                                Click="AnswerHistoryNext_Click"
                                Visibility="Collapsed">
                            <Button.ToolTip>
                                <ToolTip>
                                    <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                               Text="Show the next AI answer if you have stepped back through the history."/>
                                </ToolTip>
                            </Button.ToolTip>
                        </Button>
                    </StackPanel>
                    <Button x:Name="CloseAnswerButton" Grid.Column="2" Content="✕"
                            Width="30" Height="30" Padding="0" FontSize="14"
                            Foreground="#FCA5A5"
                            Background="#3F1D1D"
                            BorderBrush="#991B1B"
                            BorderThickness="1"
                            Click="CloseAnswerButton_Click"
                            HorizontalAlignment="Right"
                            IsHitTestVisible="True"
                            Cursor="Hand">
                        <Button.ToolTip>
                            <ToolTip>
                                <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                           Text="Hide the answer panel. Your history is kept until you generate a new answer or end the session."/>
                            </ToolTip>
                        </Button.ToolTip>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="cb" Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="9">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="cb" Property="Background" Value="#7F1D1D"/>
                                        <Setter Property="Foreground" Value="#FEE2E2"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="cb" Property="Background" Value="#450A0A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
                <Border x:Name="AiAnswerBodyBorder" Grid.Row="1" Background="#9918181B" CornerRadius="12" BorderBrush="#6366F1" BorderThickness="1"
                        MinHeight="80" Padding="10">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="1" Direction="270" Opacity="0.08" Color="#0F172A"/>
                    </Border.Effect>
                    <RichTextBox x:Name="AiAnswerTextBlock"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#F8FAFC"
                                 IsReadOnly="True"
                                 IsDocumentEnabled="False"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Disabled"
                                 FontSize="13"
                                 FontFamily="Segoe UI"
                                 FontWeight="SemiBold"
                                 ScrollViewer.CanContentScroll="False"
                                 ScrollViewer.PanningMode="VerticalOnly"/>
                </Border>
            </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
