<Window x:Class="AiInterviewAssistant.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AiInterviewAssistant"
        Title="Smeed AI"
        Width="720" MinHeight="200"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        FocusVisualStyle="{x:Null}"
        Loaded="Window_Loaded"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <!-- Shared chrome button chrome -->
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Background" Value="#2212121C"/>
            <Setter Property="Foreground" Value="{StaticResource OrioTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="9,5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#33818CF8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ClearButtonStyle" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Background" Value="#2A2A38"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#45465A"/>
        </Style>
        <!-- Compact row actions: smaller chrome, slightly larger readable type -->
        <Style x:Key="CompactActionButtonBase" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="9,4"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="MaxHeight" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.93"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.86"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CompactClearButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactActionButtonBase}">
            <Setter Property="Background" Value="#2A2A38"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#45465A"/>
            <Setter Property="MinWidth" Value="56"/>
        </Style>
        <Style x:Key="CompactPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactActionButtonBase}">
            <Setter Property="Background" Value="#5B21B6"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#7C3AED"/>
            <Setter Property="MinWidth" Value="76"/>
        </Style>
        <Style x:Key="CompactAskButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactActionButtonBase}">
            <Setter Property="Background" Value="#0F766E"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#14B8A6"/>
            <Setter Property="MinWidth" Value="46"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Background" Value="#5B21B6"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#7C3AED"/>
        </Style>
        <Style x:Key="AskButtonStyle" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Background" Value="#0F766E"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#14B8A6"/>
        </Style>
        <Style x:Key="CloseIconButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Background" Value="#1E1E2A"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Content" Value="✕"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#3F3F50"/>
        </Style>
        <Style x:Key="MainWindowCloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="BorderBrush" Value="#B91C1C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EF4444"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#B91C1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="EndSessionToolbarStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#EA580C"/>
            <Setter Property="BorderBrush" Value="#C2410C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F97316"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#C2410C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HideToolbarButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="48"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="9,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="Background" Value="#3730A3"/>
            <Setter Property="BorderBrush" Value="#6366F1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#4F46E5"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#818CF8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#312E81"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ToolbarIconCircleStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- iOS-style switch; use empty Content — label sits beside control in toolbar -->
        <Style x:Key="AutoAnswerSwitchToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Content" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Width="42" Height="22" SnapsToDevicePixels="True">
                            <Border x:Name="Track" CornerRadius="11" Height="22"
                                    Background="#2A2A38" BorderBrush="#3F3F50" BorderThickness="1"/>
                            <Border x:Name="Thumb" Width="18" Height="18" CornerRadius="9"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Margin="3,0,0,0" Background="#F1F5F9" BorderBrush="#CBD5E1" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="3" ShadowDepth="1" Direction="270" Opacity="0.25" Color="#000000"/>
                                </Border.Effect>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#0D9488"/>
                                <Setter TargetName="Track" Property="BorderBrush" Value="#14B8A6"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ChromeSliderStyle" TargetType="Slider">
            <Setter Property="Height" Value="20"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Foreground" Value="#818CF8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}"/>
                            </Grid.RowDefinitions>
                            <Border x:Name="TrackBackground" Grid.Row="1" Height="5" CornerRadius="3"
                                    Background="#2A2A38" BorderThickness="0" VerticalAlignment="Center" Margin="0,0,0,0"/>
                            <Track x:Name="PART_Track" Grid.Row="1" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}" Height="0" Width="0" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}" Height="0" Width="0" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Width="16" Height="16" Focusable="False">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="#A5B4FC" Stroke="#818CF8" StrokeThickness="1.5"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AnswerNavButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#EEF2FF"/>
            <Setter Property="Background" Value="#312E81"/>
            <Setter Property="BorderBrush" Value="#6366F1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="hb" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="hb" Property="Background" Value="#4F46E5"/>
                                <Setter TargetName="hb" Property="BorderBrush" Value="#A5B4FC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="hb" Property="Background" Value="#1E1B4B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#64748B"/>
                                <Setter TargetName="hb" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Black transparent scrollbar -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="Transparent">
                            <Border Background="#18050508" CornerRadius="4" Margin="2,4"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border Background="#55818CF8" CornerRadius="4" Margin="1,2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Startup: code sets Background transparent + SizeToContent so only the login card is visible -->
    <Border x:Name="RootChromeBorder"
            CornerRadius="16"
            Background="Transparent"
            BorderBrush="#1AFFFFFF"
            BorderThickness="1"
            Padding="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="4" Direction="270" Opacity="0.38" Color="#050508"/>
        </Border.Effect>

        <Grid>
            <local:StartupLoginView x:Name="StartupLoginView"/>
            <local:SessionSetupView x:Name="SessionSetupView" Visibility="Collapsed"/>
            <local:PastSessionsView x:Name="PastSessionsView" Visibility="Collapsed"/>
            <local:CreateSessionDetailsView x:Name="CreateSessionDetailsView" Visibility="Collapsed"/>
            <local:CreateSessionStep2View x:Name="CreateSessionStep2View" Visibility="Collapsed"/>
            <local:ActivateSessionView x:Name="ActivateSessionView" Visibility="Collapsed"/>
            <Grid x:Name="MainContentGrid" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Top bar: left tools, centered title (fill), right controls -->
            <DockPanel Grid.Row="0" Margin="0,0,0,10" LastChildFill="True">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center" Margin="4,0,16,0">
                    <Button x:Name="HideButton" Content="Hide"
                            Style="{StaticResource HideToolbarButtonStyle}"
                            Margin="0,0,8,0"
                            Click="HideButton_Click">
                        <Button.ToolTip>
                            <ToolTip>
                                <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                           Text="Hides this window. A small chip appears at the top center of your screen—click it to bring Smeed AI back (same as Hide on other screens)."/>
                            </ToolTip>
                        </Button.ToolTip>
                    </Button>
                    <Button x:Name="MicToggleButton"
                            Content="&#xE720;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="13"
                            Style="{StaticResource ToolbarIconCircleStyle}"
                            Margin="0,0,8,0"
                            Background="#10B981"
                            Foreground="#FFFFFF"
                            BorderBrush="#059669"
                            Click="MicToggleButton_Click">
                        <Button.ToolTip>
                            <ToolTip>
                                <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                           Text="Microphone capture for the interview. Green: listening. Click to mute your mic when you do not want speech sent to transcription."/>
                            </ToolTip>
                        </Button.ToolTip>
                    </Button>
                    <Button x:Name="SpeakerToggleButton"
                            Content="&#xE767;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="13"
                            Style="{StaticResource ToolbarIconCircleStyle}"
                            Margin="0,0,8,0"
                            Background="#4F46E5"
                            Foreground="#EEF2FF"
                            BorderBrush="#818CF8"
                            Click="SpeakerToggleButton_Click">
                        <Button.ToolTip>
                            <ToolTip>
                                <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                           Text="System / speaker audio (what you hear from the call). Used to capture the interviewer’s voice for transcription and auto-answer."/>
                            </ToolTip>
                        </Button.ToolTip>
                    </Button>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Auto answer"
                                   Foreground="{StaticResource OrioMutedBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   FontFamily="Segoe UI"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0">
                            <TextBlock.ToolTip>
                                <ToolTip>
                                    <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                               Text="When on, Smeed AI listens for complete questions from speaker audio and from your mic (after a short pause), then streams a suggested answer automatically."/>
                                </ToolTip>
                            </TextBlock.ToolTip>
                        </TextBlock>
                        <ToggleButton x:Name="AutoAnswerToggle"
                                      Style="{StaticResource AutoAnswerSwitchToggleStyle}"
                                      VerticalAlignment="Center"
                                      Checked="AutoAnswerToggle_Changed"
                                      Unchecked="AutoAnswerToggle_Changed">
                            <ToggleButton.ToolTip>
                                <ToolTip>
                                    <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                               Text="Turn automatic answers on or off without leaving the interview. You can still use “AI Answer” manually when this is off."/>
                                </ToolTip>
                            </ToggleButton.ToolTip>
                        </ToggleButton>
                    </StackPanel>
                </StackPanel>
                <Button Content="✕" DockPanel.Dock="Right" Margin="8,0,0,0"
                        Style="{StaticResource MainWindowCloseButtonStyle}"
                        Click="CloseButton_Click">
                    <Button.ToolTip>
                        <ToolTip>
                            <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                       Text="Closes Smeed AI completely. End the interview session first if you want a clean shutdown."/>
                        </ToolTip>
                    </Button.ToolTip>
                </Button>
                <Button x:Name="EndSessionButton"
                        Content="⏹"
                        DockPanel.Dock="Right"
                        Margin="8,0,0,0"
                        Style="{StaticResource EndSessionToolbarStyle}"
                        Click="EndSessionButton_Click"
                        IsEnabled="False">
                    <Button.ToolTip>
                        <ToolTip>
                            <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                       Text="Stops the current interview session, timers, and streaming. Your transcript may still be saved if you enabled that when creating the session."/>
                        </ToolTip>
                    </Button.ToolTip>
                </Button>
                <Border DockPanel.Dock="Right"
                        Background="#B012121C"
                        CornerRadius="8"
                        BorderBrush="#D97706"
                        BorderThickness="1"
                        Padding="8,0"
                        Height="28"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0"
                        ToolTipService.ShowDuration="60000">
                    <Border.ToolTip>
                        <ToolTip>
                            <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                       Text="Time remaining in the active interview session. The session may auto-extend shortly before it reaches zero if your plan allows it."/>
                        </ToolTip>
                    </Border.ToolTip>
                    <TextBlock x:Name="SessionTimerTextBlock"
                               Text="00:00"
                               Foreground="#FEF3C7"
                               FontWeight="SemiBold"
                               FontSize="12"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center"/>
                </Border>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                    <TextBlock Text="Opacity" Foreground="{StaticResource OrioMutedBrush}" FontSize="11" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,8,0">
                        <TextBlock.ToolTip>
                            <ToolTip>
                                <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                           Text="Dims the floating panel so you can see through to the meeting app. Question text, transcript, and answers stay fully readable."/>
                            </ToolTip>
                        </TextBlock.ToolTip>
                    </TextBlock>
                    <Slider x:Name="WindowOpacitySlider"
                            Width="100"
                            Style="{StaticResource ChromeSliderStyle}"
                            Minimum="55"
                            Maximum="100"
                            Value="90"
                            ValueChanged="WindowOpacitySlider_ValueChanged"
                            VerticalAlignment="Center"
                            TickPlacement="None"
                            IsSnapToTickEnabled="False">
                        <Slider.ToolTip>
                            <ToolTip>
                                <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                           Text="Drag to make the window more transparent over the meeting. Minimum keeps the UI readable."/>
                            </ToolTip>
                        </Slider.ToolTip>
                    </Slider>
                </StackPanel>
                <TextBlock Text="Smeed AI"
                           Foreground="{StaticResource OrioTextBrush}" FontWeight="SemiBold" FontSize="14" FontFamily="Segoe UI"
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           TextAlignment="Center"/>
            </DockPanel>

            <!-- Transcript row: full-width transcript + clear at end -->
            <Grid Grid.Row="1" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Background="#9812121C" CornerRadius="10" BorderBrush="#55818CF8" BorderThickness="1"
                        Margin="0,0,8,0" Height="36">
                    <TextBox x:Name="TranscriptTextBlock"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{StaticResource OrioTextBrush}" TextWrapping="Wrap" FontSize="12.5"
                             FontFamily="Segoe UI" FontWeight="SemiBold"
                             VerticalContentAlignment="Top" Padding="9,6"
                             IsReadOnly="True" Text=""/>
                </Border>

                <Button x:Name="TranscriptClearButton" Grid.Column="1" Content="Clear"
                        Click="TranscriptClearButton_Click" Style="{StaticResource CompactClearButtonStyle}">
                    <Button.ToolTip>
                        <ToolTip>
                            <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                       Text="Clears the live transcript text in this window only. It does not delete saved history on the server."/>
                        </ToolTip>
                    </Button.ToolTip>
                </Button>
            </Grid>

            <!-- Actions row: AI Answer, Analyze Screen, Text Input (with clear icon), Ask -->
            <Grid Grid.Row="2" Margin="0,0,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="AiAnswerButton" Grid.Column="0" Content="AI Answer"
                        Click="AiAnswerButton_Click" Style="{StaticResource CompactPrimaryButtonStyle}"
                        Margin="0,0,6,0">
                    <Button.ToolTip>
                        <ToolTip>
                            <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                       Text="Generates an answer for the latest detected or typed question using your session context (job, resume, and instructions)."/>
                        </ToolTip>
                    </Button.ToolTip>
                </Button>

                <Button x:Name="ScreenshotAiButton" Grid.Column="1" Content="Analyze screen"
                        Click="ScreenshotAiButton_Click" Style="{StaticResource CompactAskButtonStyle}"
                        Margin="0,0,8,0" MinWidth="108">
                    <Button.ToolTip>
                        <ToolTip>
                            <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                       Text="Captures all monitors (Smeed AI is hidden from the shot), reads text with OCR, then answers any interview or coding question found—using your resume and session context."/>
                        </ToolTip>
                    </Button.ToolTip>
                </Button>

                <Border Grid.Column="2" Background="#9812121C" CornerRadius="10" BorderBrush="#400D9488" BorderThickness="1"
                        Margin="0,0,8,0" Height="36">
                    <Grid>
                        <TextBox x:Name="QuestionTextBox"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource OrioTextBrush}" TextWrapping="NoWrap" FontSize="12.5"
                                 FontFamily="Segoe UI" FontWeight="SemiBold"
                                 VerticalContentAlignment="Center" Padding="9,6"
                                 Text=""/>
                        <TextBlock x:Name="QuestionPlaceholderText"
                                   Text="Type a question, paste a prompt, or ask something you want to practice…"
                                   Foreground="{StaticResource OrioMutedBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="12.5"
                                   Margin="12,0,34,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Text, ElementName=QuestionTextBox}" Value=""/>
                                                <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=QuestionTextBox}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <Button x:Name="QuestionInlineClearButton"
                                Content="✕"
                                Width="26"
                                Height="26"
                                FontSize="12"
                                FontWeight="Bold"
                                Foreground="#CBD5E1"
                                Background="#2A2A38"
                                BorderBrush="#3F3F50"
                                BorderThickness="1"
                                Cursor="Hand"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,6,0"
                                Padding="0"
                                Click="QuestionClearButton_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#3F3F50"/>
                                                        <Setter TargetName="bd" Property="BorderBrush" Value="#6366F1"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#1E1E2A"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <!-- Hide the clear icon unless the user typed something -->
                                        <DataTrigger Binding="{Binding Text, ElementName=QuestionTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <Button x:Name="AskButton" Grid.Column="3" Content="Ask"
                        Click="AskButton_Click" Style="{StaticResource CompactAskButtonStyle}">
                    <Button.ToolTip>
                        <ToolTip>
                            <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                       Text="Sends the text in the question field to the AI (driven by what you typed)."/>
                        </ToolTip>
                    </Button.ToolTip>
                </Button>
            </Grid>

            <!-- Status/debug line (always visible) -->
            <Border Grid.Row="3" Background="#9812121C" CornerRadius="10" BorderBrush="#28FFFFFF" BorderThickness="1" Padding="9,7" Margin="0,4,0,0">
                <TextBlock x:Name="StatusTextBlock"
                           Foreground="{StaticResource OrioMutedBrush}" FontSize="11" FontFamily="Segoe UI"
                           TextWrapping="Wrap" Text="Idle"/>
            </Border>

            <!-- AI Answer section: visible only when there is an answer; no space when collapsed -->
            <Grid x:Name="AnswerSectionPanel" Grid.Row="4" Margin="0,10,0,0" Visibility="Collapsed"
                  MinHeight="120">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="AI Answer:" Foreground="#C7D2FE" FontWeight="SemiBold" FontSize="12.5"
                               FontFamily="Segoe UI" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,10,0">
                        <Button x:Name="AnswerHistoryPrevButton"
                                Content="‹"
                                Style="{StaticResource AnswerNavButtonStyle}"
                                Click="AnswerHistoryPrev_Click"
                                Visibility="Collapsed"
                                Margin="0,0,6,0">
                            <Button.ToolTip>
                                <ToolTip>
                                    <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                               Text="Show the previous AI answer generated in this session."/>
                                </ToolTip>
                            </Button.ToolTip>
                        </Button>
                        <TextBlock x:Name="AnswerHistoryPositionText"
                                   Foreground="#A5B4FC" FontSize="11.5" FontWeight="SemiBold"
                                   VerticalAlignment="Center" MinWidth="36" TextAlignment="Center"
                                   Visibility="Collapsed" Margin="0,0,6,0"/>
                        <Button x:Name="AnswerHistoryNextButton"
                                Content="›"
                                Style="{StaticResource AnswerNavButtonStyle}"
                                Click="AnswerHistoryNext_Click"
                                Visibility="Collapsed">
                            <Button.ToolTip>
                                <ToolTip>
                                    <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                               Text="Show the next AI answer if you have stepped back through the history."/>
                                </ToolTip>
                            </Button.ToolTip>
                        </Button>
                    </StackPanel>
                    <Button x:Name="CloseAnswerButton" Grid.Column="2" Content="✕"
                            Width="28" Height="28" Padding="0" FontSize="13"
                            Foreground="#FCA5A5"
                            Background="#3F1D1D"
                            BorderBrush="#991B1B"
                            BorderThickness="1"
                            Click="CloseAnswerButton_Click"
                            HorizontalAlignment="Right"
                            IsHitTestVisible="True"
                            Cursor="Hand">
                        <Button.ToolTip>
                            <ToolTip>
                                <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                           Text="Hide the answer panel. Your history is kept until you generate a new answer or end the session."/>
                            </ToolTip>
                        </Button.ToolTip>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="cb" Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="cb" Property="Background" Value="#7F1D1D"/>
                                        <Setter Property="Foreground" Value="#FEE2E2"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="cb" Property="Background" Value="#450A0A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
                <Border x:Name="AiAnswerBodyBorder" Grid.Row="1" Background="#9812121C" CornerRadius="12" BorderBrush="#55818CF8" BorderThickness="1"
                        MinHeight="72" Padding="9">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="2" Direction="270" Opacity="0.22" Color="#050508"/>
                    </Border.Effect>
                    <RichTextBox x:Name="AiAnswerTextBlock"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource OrioTextBrush}"
                                 IsReadOnly="True"
                                 IsDocumentEnabled="False"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Disabled"
                                 FontSize="12.5"
                                 FontFamily="Segoe UI"
                                 FontWeight="SemiBold"
                                 ScrollViewer.CanContentScroll="False"
                                 ScrollViewer.PanningMode="VerticalOnly"/>
                </Border>
            </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
