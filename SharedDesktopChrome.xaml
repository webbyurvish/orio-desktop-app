<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══ Smeed AI desktop — full Aurora Stealth (web .orio-app parity) ═══ -->

    <SolidColorBrush x:Key="OrioVoidBrush" Color="#050508"/>
    <SolidColorBrush x:Key="OrioSurfaceBrush" Color="#0C0C12"/>
    <SolidColorBrush x:Key="OrioElevatedBrush" Color="#12121C"/>
    <SolidColorBrush x:Key="OrioTextBrush" Color="#E2E8F0"/>
    <SolidColorBrush x:Key="OrioMutedBrush" Color="#94A3B8"/>
    <SolidColorBrush x:Key="OrioBorderSubtleBrush" Color="#14FFFFFF"/>
    <SolidColorBrush x:Key="OrioBorderMediumBrush" Color="#22FFFFFF"/>

    <LinearGradientBrush x:Key="OrioShellCardFaceBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#0C0C12" Offset="0"/>
        <GradientStop Color="#08080E" Offset="1"/>
    </LinearGradientBrush>

    <DropShadowEffect x:Key="OrioCardDropShadow"
                      BlurRadius="28"
                      ShadowDepth="4"
                      Direction="270"
                      Opacity="0.45"
                      Color="#000000"/>

    <!-- Floating window / card chrome -->
    <Style x:Key="OrioShellCardBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource OrioShellCardFaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OrioBorderMediumBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Effect" Value="{StaticResource OrioCardDropShadow}"/>
    </Style>

    <Style x:Key="OrioShellBodyBorder" TargetType="Border">
        <Setter Property="Background" Value="#08080E"/>
        <Setter Property="CornerRadius" Value="0,0,16,16"/>
        <Setter Property="Padding" Value="12,10,12,12"/>
    </Style>

    <Style x:Key="OrioPopupShell" TargetType="Border">
        <Setter Property="Background" Value="#12121C"/>
        <Setter Property="BorderBrush" Value="{StaticResource OrioBorderMediumBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="28" ShadowDepth="4" Direction="270" Opacity="0.5" Color="#000000"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="OrioPopupEmailChip" TargetType="Border">
        <Setter Property="Background" Value="#18FFFFFF"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>

    <Style x:Key="OrioTabTrayBorder" TargetType="Border">
        <Setter Property="Background" Value="#0C0C12"/>
        <Setter Property="BorderBrush" Value="{StaticResource OrioBorderSubtleBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="4"/>
    </Style>

    <Style x:Key="OrioTabSegmentSelected" TargetType="Border">
        <Setter Property="Background" Value="#242433"/>
        <Setter Property="BorderBrush" Value="#55818CF8"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="8,7"/>
    </Style>

    <Style x:Key="OrioTabSegmentIdle" TargetType="Border">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="8,7"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#12FFFFFF"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="OrioSecondaryGhostBtn" TargetType="Border">
        <Setter Property="Background" Value="#18FFFFFF"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="9"/>
        <Setter Property="Padding" Value="9,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#26FFFFFF"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="OrioOutlineSecondaryBtn" TargetType="Border" BasedOn="{StaticResource OrioSecondaryGhostBtn}">
        <Setter Property="BorderBrush" Value="#55818CF8"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="OrioFieldHostBorder" TargetType="Border">
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="BorderBrush" Value="{StaticResource OrioBorderMediumBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="#14141E"/>
        <Setter Property="Padding" Value="2,2"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style x:Key="OrioInnerFormPanelBorder" TargetType="Border">
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="BorderBrush" Value="{StaticResource OrioBorderSubtleBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,12"/>
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#16161F" Offset="0"/>
                    <GradientStop Color="#101018" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="OrioSessionsListPanelBorder" TargetType="Border" BasedOn="{StaticResource OrioInnerFormPanelBorder}">
        <Setter Property="Padding" Value="0"/>
    </Style>

    <!-- Legacy key used in older XAML — maps to dark tab tray -->
    <Style x:Key="OrioTabSwitcherBarBorder" TargetType="Border" BasedOn="{StaticResource OrioTabTrayBorder}">
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>

    <Style x:Key="OrioTooltipBodyText" TargetType="TextBlock">
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Foreground" Value="#F1F5F9"/>
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="LineHeight" Value="19"/>
        <Setter Property="MaxWidth" Value="268"/>
    </Style>

    <Style x:Key="OrioTooltipStyle" TargetType="ToolTip">
        <Setter Property="ToolTipService.ShowDuration" Value="60000"/>
        <Setter Property="ToolTipService.InitialShowDelay" Value="275"/>
        <Setter Property="ToolTipService.BetweenShowDelay" Value="120"/>
        <Setter Property="Placement" Value="Bottom"/>
        <Setter Property="VerticalOffset" Value="6"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="MaxWidth" Value="292"/>
        <Setter Property="Foreground" Value="#F1F5F9"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="#12121C"
                            BorderBrush="#818CF8"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12,10"
                            MaxWidth="292"
                            SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="4" Direction="270" Opacity="0.35" Color="#000000"/>
                        </Border.Effect>
                        <ContentPresenter
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="OrioInfoHintGlyph" TargetType="TextBlock">
        <Setter Property="Text" Value="i"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="7"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#6694A3B8"/>
    </Style>

    <Style x:Key="OrioInfoHintBorder" TargetType="Border">
        <Setter Property="Width" Value="12"/>
        <Setter Property="Height" Value="12"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Background" Value="#0FFFFFFF"/>
        <Setter Property="BorderBrush" Value="#28818CF8"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Margin" Value="5,0,0,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="ToolTipService.ShowDuration" Value="60000"/>
        <Setter Property="ToolTipService.InitialShowDelay" Value="250"/>
        <Setter Property="ToolTipService.BetweenShowDelay" Value="100"/>
        <Setter Property="ToolTipService.Placement" Value="Top"/>
        <Setter Property="ToolTipService.VerticalOffset" Value="-6"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#18FFFFFF"/>
                <Setter Property="BorderBrush" Value="#45818CF8"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="OrioComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="#E2E8F0"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="ItemBg"
                            Margin="4,2"
                            Padding="12,8"
                            CornerRadius="8"
                            Background="Transparent"
                            BorderThickness="0"
                            SnapsToDevicePixels="True">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemBg" Property="Background" Value="#22FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemBg" Property="Background" Value="#303A4C6E"/>
                            <Setter TargetName="ItemBg" Property="BorderBrush" Value="#66818CF8"/>
                            <Setter TargetName="ItemBg" Property="BorderThickness" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ItemBg" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="OrioComboBoxTemplate" TargetType="ComboBox">
        <Grid SnapsToDevicePixels="True">
            <Border x:Name="mainBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="10"
                    SnapsToDevicePixels="True">
                <Grid>
                    <ToggleButton x:Name="ToggleButton"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Focusable="False"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                  ClickMode="Press">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border Background="Transparent" SnapsToDevicePixels="True"/>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                    <Grid IsHitTestVisible="False" Margin="{TemplateBinding Padding}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ContentPresenter x:Name="ContentSite"
                                          Grid.Column="0"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          SnapsToDevicePixels="True"/>
                        <Path Grid.Column="1"
                              Data="M 0 0.5 L 4 4.5 L 8 0.5 Z"
                              Fill="#C4B5FD"
                              Margin="8,0,5,0"
                              Width="8"
                              Height="4.5"
                              Stretch="Fill"
                              VerticalAlignment="Center"
                              Opacity="0.95"/>
                    </Grid>
                </Grid>
            </Border>
            <Popup x:Name="PART_Popup"
                   AllowsTransparency="True"
                   Focusable="False"
                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                   Placement="Bottom"
                   PlacementTarget="{Binding ElementName=mainBorder}"
                   PopupAnimation="Fade"
                   VerticalOffset="3">
                <Border MinWidth="{Binding ActualWidth, ElementName=mainBorder}"
                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                        Background="#16161F"
                        BorderBrush="{StaticResource OrioBorderMediumBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        SnapsToDevicePixels="True"
                        Margin="0,2,0,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="6" Direction="270" Opacity="0.4" Color="#000000"/>
                    </Border.Effect>
                    <ScrollViewer CanContentScroll="True"
                                  HorizontalScrollBarVisibility="Disabled"
                                  SnapsToDevicePixels="True"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="2,5,2,6">
                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" SnapsToDevicePixels="True"/>
                    </ScrollViewer>
                </Border>
            </Popup>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="mainBorder" Property="BorderBrush" Value="#55818CF8"/>
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter TargetName="mainBorder" Property="BorderBrush" Value="#77A78BFA"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="mainBorder" Property="Opacity" Value="0.55"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="OrioComboBoxStyle" TargetType="ComboBox">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource OrioComboBoxItemStyle}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        <Setter Property="MinHeight" Value="38"/>
        <Setter Property="MaxDropDownHeight" Value="300"/>
        <Setter Property="Padding" Value="9,7"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#E2E8F0"/>
        <Setter Property="Background" Value="#14141E"/>
        <Setter Property="BorderBrush" Value="{StaticResource OrioBorderMediumBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template" Value="{StaticResource OrioComboBoxTemplate}"/>
    </Style>

    <Style x:Key="OrioFormTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="9,6"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="#E2E8F0"/>
        <Setter Property="CaretBrush" Value="#2DD4BF"/>
        <Setter Property="SelectionBrush" Value="#556366F1"/>
    </Style>

    <Style x:Key="OrioFormMultilineTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource OrioFormTextBoxStyle}">
        <Setter Property="Padding" Value="10,8"/>
    </Style>

    <Style x:Key="OrioSwitchToggleStyle" TargetType="ToggleButton">
        <Setter Property="Width" Value="44"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid SnapsToDevicePixels="True">
                        <Border x:Name="Track"
                                Height="24"
                                CornerRadius="12"
                                Background="#2A2A38"
                                BorderBrush="#3F3F50"
                                BorderThickness="1"/>
                        <Border x:Name="Knob"
                                Width="20"
                                Height="20"
                                CornerRadius="10"
                                HorizontalAlignment="Left"
                                Margin="2,0,0,0"
                                VerticalAlignment="Center"
                                Background="#3D3D4A"
                                BorderBrush="#52525E"
                                BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="3" ShadowDepth="1" Direction="270" Opacity="0.25" Color="#000000"/>
                            </Border.Effect>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Track" Property="Opacity" Value="0.94"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Track" Property="Opacity" Value="0.88"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="#0D9488"/>
                            <Setter TargetName="Track" Property="BorderBrush" Value="#14B8A6"/>
                            <Setter TargetName="Knob" Property="Background" Value="#F8FAFC"/>
                            <Setter TargetName="Knob" Property="BorderBrush" Value="#CCFBF1"/>
                            <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right"/>
                            <Setter TargetName="Knob" Property="Margin" Value="0,0,2,0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="OrioSessionTileFreeStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="BorderBrush" Value="{StaticResource OrioBorderMediumBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="#18FFFFFF"/>
        <Setter Property="Padding" Value="10,10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#24FFFFFF"/>
                <Setter Property="BorderBrush" Value="#55818CF8"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="OrioSessionTileFullStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="BorderBrush" Value="#662DD4BF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#115E59" Offset="0"/>
                    <GradientStop Color="#3730A3" Offset="0.55"/>
                    <GradientStop Color="#1E1B4B" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Opacity" Value="0.96"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="OrioMoveSlotBtnStyle" TargetType="Border">
        <Setter Property="Width" Value="56"/>
        <Setter Property="Height" Value="42"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Background" Value="#1A1A26"/>
        <Setter Property="BorderBrush" Value="{StaticResource OrioBorderMediumBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Margin" Value="3"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#262632"/>
                <Setter Property="BorderBrush" Value="#66818CF8"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="MenuRowButton" TargetType="Border">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#18FFFFFF"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="MenuTinyIconBtn" TargetType="Border">
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#18FFFFFF"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <LinearGradientBrush x:Key="OrioAuroraHeaderBrush" StartPoint="0,0" EndPoint="1,0.35">
        <GradientStop Color="#0C0C12" Offset="0"/>
        <GradientStop Color="#12121C" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="OrioAuroraHeaderDividerBrush" Color="#14FFFFFF"/>

    <Style x:Key="OrioHdrGhostBtn" TargetType="Border">
        <Setter Property="Width" Value="30"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="CornerRadius" Value="9"/>
        <Setter Property="Background" Value="#18FFFFFF"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Margin" Value="0,0,4,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#2AFFFFFF"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="OrioHdrCloseBtn" TargetType="Border">
        <Setter Property="Width" Value="30"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="CornerRadius" Value="9"/>
        <Setter Property="Background" Value="#40E11D48"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Margin" Value="4,0,0,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#5CF43F5E"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
