<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Card elevation (apply: Border.Effect="{StaticResource OrioCardDropShadow}") -->
    <DropShadowEffect x:Key="OrioCardDropShadow"
                      BlurRadius="32"
                      ShadowDepth="6"
                      Direction="270"
                      Opacity="0.13"
                      Color="#1E1B4B"/>

    <!-- Form field wrapper -->
    <Style x:Key="OrioFieldHostBorder" TargetType="Border">
        <Setter Property="CornerRadius" Value="11"/>
        <Setter Property="BorderBrush" Value="#A5B4FC"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="Background" Value="#FAFBFF"/>
        <Setter Property="Padding" Value="3,3"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style x:Key="OrioInnerFormPanelBorder" TargetType="Border">
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="BorderBrush" Value="#E0E7FF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="14,14"/>
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FFFFFF" Offset="0"/>
                    <GradientStop Color="#F8FAFF" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="OrioSessionsListPanelBorder" TargetType="Border" BasedOn="{StaticResource OrioInnerFormPanelBorder}">
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style x:Key="OrioTabSwitcherBarBorder" TargetType="Border">
        <Setter Property="Background" Value="#EEF2FF"/>
        <Setter Property="BorderBrush" Value="#C7D2FE"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="Padding" Value="6"/>
    </Style>

    <!-- Body copy inside card tooltips (use with implicit ToolTip style) -->
    <Style x:Key="OrioTooltipBodyText" TargetType="TextBlock">
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Foreground" Value="#F1F5F9"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="LineHeight" Value="20"/>
        <Setter Property="MaxWidth" Value="268"/>
    </Style>

    <!-- Card-style tooltips: max width, rounded panel (apply app-wide via implicit ToolTip style) -->
    <Style x:Key="OrioTooltipStyle" TargetType="ToolTip">
        <Setter Property="ToolTipService.ShowDuration" Value="60000"/>
        <Setter Property="ToolTipService.InitialShowDelay" Value="275"/>
        <Setter Property="ToolTipService.BetweenShowDelay" Value="120"/>
        <Setter Property="Placement" Value="Bottom"/>
        <Setter Property="VerticalOffset" Value="6"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="MaxWidth" Value="292"/>
        <Setter Property="Foreground" Value="#F1F5F9"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="#1E1B4B"
                            BorderBrush="#818CF8"
                            BorderThickness="1.5"
                            CornerRadius="12"
                            Padding="14,12"
                            MaxWidth="292"
                            SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18" ShadowDepth="5" Direction="270" Opacity="0.32" Color="#000000"/>
                        </Border.Effect>
                        <ContentPresenter
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- "i" hint chip next to labels: help cursor + hover -->
    <Style x:Key="OrioInfoHintBorder" TargetType="Border">
        <Setter Property="Width" Value="20"/>
        <Setter Property="Height" Value="20"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Background" Value="#EEF2FF"/>
        <Setter Property="BorderBrush" Value="#A5B4FC"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="Margin" Value="8,0,0,0"/>
        <Setter Property="Cursor" Value="Help"/>
        <Setter Property="ToolTipService.ShowDuration" Value="60000"/>
        <Setter Property="ToolTipService.InitialShowDelay" Value="250"/>
        <Setter Property="ToolTipService.BetweenShowDelay" Value="100"/>
        <Setter Property="ToolTipService.Placement" Value="Top"/>
        <Setter Property="ToolTipService.VerticalOffset" Value="-6"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#E0E7FF"/>
                <Setter Property="BorderBrush" Value="#6366F1"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Dropdown list rows -->
    <Style x:Key="OrioComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="ItemBg"
                            Margin="6,3"
                            Padding="14,11"
                            CornerRadius="10"
                            Background="Transparent"
                            BorderThickness="0"
                            SnapsToDevicePixels="True">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemBg" Property="Background" Value="#EEF2FF"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemBg" Property="Background" Value="#E0E7FF"/>
                            <Setter TargetName="ItemBg" Property="BorderBrush" Value="#A5B4FC"/>
                            <Setter TargetName="ItemBg" Property="BorderThickness" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ItemBg" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Rounded combo: matches OrioFieldHostBorder colors; requires template parts ToggleButton + PART_Popup -->
    <ControlTemplate x:Key="OrioComboBoxTemplate" TargetType="ComboBox">
        <Grid SnapsToDevicePixels="True">
            <Border x:Name="mainBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="11"
                    SnapsToDevicePixels="True">
                <Grid>
                    <ToggleButton x:Name="ToggleButton"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Focusable="False"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                  ClickMode="Press">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border Background="Transparent" SnapsToDevicePixels="True"/>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                    <Grid IsHitTestVisible="False" Margin="{TemplateBinding Padding}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ContentPresenter x:Name="ContentSite"
                                          Grid.Column="0"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          SnapsToDevicePixels="True"/>
                        <Path Grid.Column="1"
                              Data="M 0 0.5 L 4 4.5 L 8 0.5 Z"
                              Fill="#4F46E5"
                              Margin="10,0,6,0"
                              Width="9"
                              Height="5"
                              Stretch="Fill"
                              VerticalAlignment="Center"
                              Opacity="0.9"/>
                    </Grid>
                </Grid>
            </Border>
            <Popup x:Name="PART_Popup"
                   AllowsTransparency="True"
                   Focusable="False"
                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                   Placement="Bottom"
                   PlacementTarget="{Binding ElementName=mainBorder}"
                   PopupAnimation="Fade"
                   VerticalOffset="4">
                <Border MinWidth="{Binding ActualWidth, ElementName=mainBorder}"
                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                        Background="#FAFBFF"
                        BorderBrush="#A5B4FC"
                        BorderThickness="1.5"
                        CornerRadius="11"
                        SnapsToDevicePixels="True"
                        Margin="0,2,0,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="22" ShadowDepth="6" Direction="270" Opacity="0.16" Color="#312E81"/>
                    </Border.Effect>
                    <ScrollViewer CanContentScroll="True"
                                  HorizontalScrollBarVisibility="Disabled"
                                  SnapsToDevicePixels="True"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="2,6,2,8">
                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" SnapsToDevicePixels="True"/>
                    </ScrollViewer>
                </Border>
            </Popup>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="mainBorder" Property="BorderBrush" Value="#818CF8"/>
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter TargetName="mainBorder" Property="BorderBrush" Value="#6366F1"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="mainBorder" Property="Opacity" Value="0.55"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="OrioComboBoxStyle" TargetType="ComboBox">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource OrioComboBoxItemStyle}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        <Setter Property="MinHeight" Value="44"/>
        <Setter Property="MaxDropDownHeight" Value="320"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="FontSize" Value="13.5"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#0F172A"/>
        <Setter Property="Background" Value="#FAFBFF"/>
        <Setter Property="BorderBrush" Value="#A5B4FC"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template" Value="{StaticResource OrioComboBoxTemplate}"/>
    </Style>

    <Style x:Key="OrioFormTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="FontSize" Value="13.5"/>
        <Setter Property="Foreground" Value="#0F172A"/>
        <Setter Property="CaretBrush" Value="#4F46E5"/>
        <Setter Property="SelectionBrush" Value="#C7D2FE"/>
    </Style>

    <Style x:Key="OrioFormMultilineTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource OrioFormTextBoxStyle}">
        <Setter Property="Padding" Value="12,10"/>
    </Style>

    <!-- Toggle switch: emerald on -->
    <Style x:Key="OrioSwitchToggleStyle" TargetType="ToggleButton">
        <Setter Property="Width" Value="48"/>
        <Setter Property="Height" Value="26"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid SnapsToDevicePixels="True">
                        <Border x:Name="Track"
                                Height="26"
                                CornerRadius="13"
                                Background="#E2E8F0"
                                BorderBrush="#94A3B8"
                                BorderThickness="1"/>
                        <Border x:Name="Knob"
                                Width="22"
                                Height="22"
                                CornerRadius="11"
                                HorizontalAlignment="Left"
                                Margin="3,0,0,0"
                                VerticalAlignment="Center"
                                Background="#FFFFFF"
                                BorderBrush="#CBD5E1"
                                BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Direction="270" Opacity="0.18" Color="#000000"/>
                            </Border.Effect>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Track" Property="Opacity" Value="0.94"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Track" Property="Opacity" Value="0.88"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="#059669"/>
                            <Setter TargetName="Track" Property="BorderBrush" Value="#047857"/>
                            <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right"/>
                            <Setter TargetName="Knob" Property="Margin" Value="0,0,3,0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Session setup: Free session tile -->
    <Style x:Key="OrioSessionTileFreeStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="BorderBrush" Value="#A5B4FC"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="Padding" Value="12,12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#F5F7FF"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="OrioSessionTileFullStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="BorderBrush" Value="#312E81"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                    <GradientStop Color="#3730A3" Offset="0"/>
                    <GradientStop Color="#1E1B4B" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Opacity" Value="0.94"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Move grid tiles -->
    <Style x:Key="OrioMoveSlotBtnStyle" TargetType="Border">
        <Setter Property="Width" Value="72"/>
        <Setter Property="Height" Value="56"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="#C7D2FE"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Margin" Value="4"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#EEF2FF"/>
                <Setter Property="BorderBrush" Value="#818CF8"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
