<UserControl x:Class="AiInterviewAssistant.AppHeaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             x:Name="Root"
             MinHeight="48">

    <!-- Aurora Stealth shell (web .orio-app); navbar = borderless layered ghost buttons -->

    <Border Background="{Binding HeaderBackground, ElementName=Root}"
            CornerRadius="16,16,0,0"
            BorderBrush="{Binding HeaderBorderBrush, ElementName=Root}"
            BorderThickness="0,0,0,1"
            Padding="14,9,14,9"
            ClipToBounds="True"
            MouseLeftButtonDown="HeaderBorder_MouseLeftButtonDown">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="2,0,10,0">
                <Border Width="42" Height="42"
                        Margin="0,0,10,0"
                        CornerRadius="21"
                        Background="Transparent"
                        ClipToBounds="True"
                        SnapsToDevicePixels="True"
                        UseLayoutRounding="True"
                        VerticalAlignment="Center">
                    <Image Source="pack://siteoforigin:,,,/assets/smeed-logo.png"
                           Stretch="UniformToFill"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>
                <TextBlock Text="Smeed AI"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#E2E8F0"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <Border Grid.Column="1" Background="Transparent" Padding="0,0,2,0" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Credits: elevated “chip” layer, no hard border -->
                    <Border CornerRadius="8"
                            Padding="8,5"
                            Margin="0,0,8,0"
                            BorderThickness="0"
                            ToolTipService.ShowDuration="60000">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#1FFFFFFF" Offset="0"/>
                                <GradientStop Color="#12FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.ToolTip>
                            <ToolTip>
                                <TextBlock Style="{StaticResource OrioTooltipBodyText}"
                                           Text="Interview credits remaining on your account. Creating sessions may be free; activating a paid session uses credits as shown in session setup."/>
                            </ToolTip>
                        </Border.ToolTip>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="CashMultiple"
                                                        Width="14"
                                                        Height="14"
                                                        Foreground="#5EEAD4"
                                                        Margin="0,0,6,0"
                                                        VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding CreditsText, ElementName=Root}"
                                       Foreground="#E2E8F0"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="MoreMenuAnchor"
                            Style="{StaticResource OrioHdrGhostBtn}"
                            MouseLeftButtonDown="MoreMenuAnchor_MouseLeftButtonDown"
                            ToolTipService.ShowDuration="60000">
                        <Border.ToolTip>
                            <ToolTip>
                                <TextBlock Style="{StaticResource OrioTooltipBodyText}" Text="More options: open the dashboard or sign out."/>
                            </ToolTip>
                        </Border.ToolTip>
                        <iconPacks:PackIconMaterial Kind="DotsVertical"
                                                    Width="15"
                                                    Height="15"
                                                    Foreground="#CBD5E1"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                    </Border>

                    <Border x:Name="MoveMenuAnchor"
                            Style="{StaticResource OrioHdrGhostBtn}"
                            MouseLeftButtonDown="MoveMenuAnchor_MouseLeftButtonDown"
                            ToolTipService.ShowDuration="60000">
                        <Border.ToolTip>
                            <ToolTip>
                                <TextBlock Style="{StaticResource OrioTooltipBodyText}" Text="Move the window to a corner or edge of your screen."/>
                            </ToolTip>
                        </Border.ToolTip>
                        <iconPacks:PackIconMaterial Kind="CursorMove"
                                                    Width="15"
                                                    Height="15"
                                                    Foreground="#CBD5E1"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                    </Border>

                    <Border Style="{StaticResource OrioHdrGhostBtn}"
                            MouseLeftButtonDown="MinimizeBorder_MouseLeftButtonDown"
                            ToolTipService.ShowDuration="60000">
                        <Border.ToolTip>
                            <ToolTip>
                                <TextBlock Style="{StaticResource OrioTooltipBodyText}" Text="Hide to a small chip at the top of the screen. Click the chip to bring the window back."/>
                            </ToolTip>
                        </Border.ToolTip>
                        <iconPacks:PackIconMaterial Kind="ChevronUp"
                                                    Width="16"
                                                    Height="16"
                                                    Foreground="#CBD5E1"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                    </Border>

                    <Border Style="{StaticResource OrioHdrCloseBtn}"
                            MouseLeftButtonDown="CloseBorder_MouseLeftButtonDown"
                            ToolTipService.ShowDuration="60000">
                        <Border.ToolTip>
                            <ToolTip>
                                <TextBlock Style="{StaticResource OrioTooltipBodyText}" Text="Close this window. If a session is running, use End session first if you want to keep your progress."/>
                            </ToolTip>
                        </Border.ToolTip>
                        <iconPacks:PackIconMaterial Kind="Close"
                                                    Width="14"
                                                    Height="14"
                                                    Foreground="#FCE7F3"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
