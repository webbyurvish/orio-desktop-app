<UserControl x:Class="AiInterviewAssistant.AppHeaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             x:Name="Root"
             MinHeight="64">

    <UserControl.Resources>
        <Style x:Key="DarkTooltipStyle" TargetType="ToolTip">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#111827"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Placement" Value="Bottom"/>
            <Setter Property="HasDropShadow" Value="False"/>
        </Style>

        <Style x:Key="HdrIconBtn" TargetType="Border">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Background" Value="#F1F4F9"/>
            <Setter Property="BorderBrush" Value="#D8DEE8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <Border Background="{Binding HeaderBackground, ElementName=Root}"
            CornerRadius="20,20,0,0"
            BorderBrush="{Binding HeaderBorderBrush, ElementName=Root}"
            BorderThickness="0,0,0,1"
            Padding="18,14,22,14"
            ClipToBounds="True"
            MouseLeftButtonDown="HeaderBorder_MouseLeftButtonDown">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0,12,0">
                <Ellipse Width="32" Height="32" Fill="#22C55E" Margin="0,0,10,0"/>
                <TextBlock Text="ParakeetAI" FontSize="19" FontWeight="SemiBold" Foreground="#0F172A"/>
            </StackPanel>

            <Border Grid.Column="1" Background="Transparent" Padding="0,0,18,0" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#111827" CornerRadius="12" Padding="14,7" Margin="0,0,10,0" BorderThickness="0">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="CashMultiple" Width="16" Height="16" Foreground="White" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding CreditsText, ElementName=Root}" Foreground="#F8FAFC" FontSize="12.5" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="MoreMenuAnchor"
                            Style="{StaticResource HdrIconBtn}"
                            MouseLeftButtonDown="MoreMenuAnchor_MouseLeftButtonDown"
                            ToolTipService.ShowDuration="60000">
                        <Border.ToolTip>
                            <ToolTip Style="{StaticResource DarkTooltipStyle}" Content="More"/>
                        </Border.ToolTip>
                        <iconPacks:PackIconMaterial Kind="DotsVertical" Width="16" Height="16" Foreground="#334155" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <Border x:Name="MoveMenuAnchor" Style="{StaticResource HdrIconBtn}" MouseLeftButtonDown="MoveMenuAnchor_MouseLeftButtonDown">
                        <iconPacks:PackIconMaterial Kind="CursorMove" Width="16" Height="16" Foreground="#334155" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <Border Style="{StaticResource HdrIconBtn}"
                            MouseLeftButtonDown="MinimizeBorder_MouseLeftButtonDown"
                            ToolTipService.ShowDuration="60000">
                        <Border.ToolTip>
                            <ToolTip Style="{StaticResource DarkTooltipStyle}" Content="Hide"/>
                        </Border.ToolTip>
                        <iconPacks:PackIconMaterial Kind="ChevronUp" Width="18" Height="18" Foreground="#334155" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <Border Background="#E45673"
                            BorderBrush="#D94868"
                            BorderThickness="1"
                            CornerRadius="10"
                            Width="38"
                            Height="38"
                            Margin="4,0,0,0"
                            Cursor="Hand"
                            MouseLeftButtonDown="CloseBorder_MouseLeftButtonDown"
                            ToolTipService.ShowDuration="60000">
                        <Border.ToolTip>
                            <ToolTip Style="{StaticResource DarkTooltipStyle}" Content="Close"/>
                        </Border.ToolTip>
                        <iconPacks:PackIconMaterial Kind="Close" Width="16" Height="16" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
